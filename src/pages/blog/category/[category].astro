---
import { getCollection } from 'astro:content';
import MainLayout from '../../../layouts/MainLayout.astro';
import BlogCard from '../../../components/blog/BlogCard.astro';

const CATEGORY_LABELS: Record<string, string> = {
  'direct-primary-care': 'Direct Primary Care',
  'lifestyle-medicine': 'Lifestyle Medicine',
  'preventive-medicine': 'Preventive Care',
  'patient-experience': 'Patient Experience',
  'concierge-medicine': 'Concierge Medicine',
};

export async function getStaticPaths() {
  const entries = await getCollection('blog');
  const categories = [...new Set(
    entries
      .filter(e => !e.data.draft && e.data.category)
      .map(e => e.data.category as string)
  )];

  return categories.map(cat => ({
    params: { category: cat },
    props: {
      posts: entries
        .filter(e => !e.data.draft && e.data.category === cat)
        .sort((a, b) => {
          const aDate = a.data.date ? new Date(a.data.date).getTime() : 0;
          const bDate = b.data.date ? new Date(b.data.date).getTime() : 0;
          return bDate - aDate;
        }),
    },
  }));
}

const { category } = Astro.params;
const { posts } = Astro.props;
const label = CATEGORY_LABELS[category] ?? category;

const allCategories = Object.entries(CATEGORY_LABELS);

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.forwardfamilymedicine.com" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://www.forwardfamilymedicine.com/blog" },
    { "@type": "ListItem", "position": 3, "name": label, "item": `https://www.forwardfamilymedicine.com/blog/category/${category}` },
  ],
};
---

<MainLayout
  title={`${label} Articles | Forward Family Medicine Blog`}
  description={`Evidence-based ${label.toLowerCase()} articles from Dr. Bigley and Dr. Lieberman at Forward Family Medicine — Wayne, PA.`}
  schema={breadcrumb}
>
  <section class="cat-hero section" style="background: linear-gradient(160deg, var(--cream-100) 0%, var(--cream-300) 100%);">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a> <span aria-hidden="true">›</span>
        <a href="/blog">Blog</a> <span aria-hidden="true">›</span>
        <span>{label}</span>
      </nav>
      <span class="section-label">Category</span>
      <h1>{label}</h1>
      <div class="divider"></div>
      <p class="post-count">{posts.length} article{posts.length !== 1 ? 's' : ''}</p>
    </div>
  </section>

  <section class="cat-nav-section" style="background: var(--cream-200); border-bottom: 1px solid var(--cream-300);">
    <div class="container">
      <nav class="cat-tabs" aria-label="Blog categories">
        <a href="/blog" class="cat-tab">All</a>
        {allCategories.map(([slug, display]) => (
          <a
            href={`/blog/category/${slug}`}
            class={`cat-tab${slug === category ? ' active' : ''}`}
            aria-current={slug === category ? 'page' : undefined}
          >
            {display}
          </a>
        ))}
      </nav>
    </div>
  </section>

  <section class="blog-grid-section section" style="background: var(--cream-100);">
    <div class="container">
      {posts.length > 0 ? (
        <div class="blog-grid">
          {posts.map(post => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              author={post.data.author ?? 'Forward Family Medicine'}
              date={post.data.date ?? new Date().toISOString()}
              slug={post.id.replace(/\.mdx?$/, '')}
              category={post.data.category}
              featuredImage={post.data.image}
            />
          ))}
        </div>
      ) : (
        <p class="no-posts">No articles in this category yet.</p>
      )}
    </div>
  </section>
</MainLayout>

<style>
  .breadcrumb {
    font-size: 0.85rem;
    color: var(--ink-300);
    margin-bottom: 1.5rem;
  }
  .breadcrumb a { color: var(--green-300); text-decoration: none; }
  .post-count {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--green-400);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .cat-nav-section { padding: 0; }
  .cat-tabs {
    display: flex;
    gap: 0;
    flex-wrap: wrap;
    padding: 0.5rem 0;
  }
  .cat-tab {
    padding: 0.55rem 1.1rem;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--ink-500);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: color 0.15s, background 0.15s;
    white-space: nowrap;
  }
  .cat-tab:hover { color: var(--green-400); background: var(--green-50); }
  .cat-tab.active {
    color: var(--green-500);
    background: var(--green-50);
    border-bottom: 2px solid var(--green-400);
    border-radius: var(--radius-sm) var(--radius-sm) 0 0;
  }
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .no-posts {
    color: var(--ink-400);
    font-size: 1rem;
    text-align: center;
    padding: 3rem 0;
  }
  @media (max-width: 860px) { .blog-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 540px) { .blog-grid { grid-template-columns: 1fr; } }
</style>
