---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import BlogCard from '../../components/blog/BlogCard.astro';

const entries = await getCollection('blog');
const posts = entries
  .filter(e => !e.data.draft)
  .sort((a, b) => {
    const aDate = a.data.date ? new Date(a.data.date).getTime() : 0;
    const bDate = b.data.date ? new Date(b.data.date).getTime() : 0;
    return bDate - aDate;
  });

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.forwardfamilymedicine.com" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://www.forwardfamilymedicine.com/blog" }
  ]
};
---

<MainLayout
  title="Direct Primary Care & Lifestyle Medicine Blog | Forward Family Medicine Wayne PA"
  description="Evidence-based articles on direct primary care and lifestyle medicine from Dr. Bigley and Dr. Lieberman at Forward Family Medicine — Wayne, PA."
  schema={breadcrumb}
>
  <section class="blog-hero section" style="background: linear-gradient(160deg, var(--cream-100) 0%, var(--cream-300) 100%);">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a> <span aria-hidden="true">›</span> <span>Blog</span>
      </nav>
      <span class="section-label">From Our Physicians</span>
      <h1>Health &amp; Wellness Blog</h1>
      <div class="divider"></div>
      <p class="section-intro">
        Evidence-based articles from Dr. Bigley and Dr. Lieberman — on Direct Primary Care,
        Lifestyle Medicine, nutrition, sleep, chronic disease, and living well on the Main Line.
      </p>
      <p class="post-count">{posts.length} articles</p>
    </div>
  </section>

  <section class="blog-grid-section section">
    <div class="container">
      {posts.length > 0 ? (
        <div class="blog-grid">
          {posts.map(post => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              author={post.data.author ?? 'Forward Family Medicine'}
              date={post.data.date ?? new Date().toISOString()}
              slug={post.id.replace(/\.mdx?$/, '')}
              tags={post.data.keywords}
              featuredImage={post.data.image}
            />
          ))}
        </div>
      ) : (
        <div class="blog-empty">
          <div class="blog-empty-inner card">
            <span class="blog-empty-icon" aria-hidden="true">📝</span>
            <h2>Articles Coming Soon</h2>
            <p>
              Dr. Bigley and Dr. Lieberman are preparing evidence-based articles on lifestyle
              medicine, nutrition, Direct Primary Care, and living well. Check back soon.
            </p>
            <p>
              In the meantime, <a href="/contact">schedule a free meet and greet</a> to have
              a real conversation about your health.
            </p>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Lifestyle Library promo -->
  <section class="blog-cta section" style="background: var(--cream-200);">
    <div class="container blog-cta-inner">
      <div style="max-width:480px;">
        <span class="section-label">Stay Informed</span>
        <h2>Medicine Worth Reading</h2>
        <p>
          Our physicians write about what actually matters for your health — without the
          noise. New articles monthly, authored by Dr. Bigley or Dr. Lieberman.
        </p>
        <a href="/contact" class="btn btn-accent">Schedule a Free Meet &amp; Greet</a>
      </div>
      <div class="lifestyle-promo card">
        <span class="section-label">Also Explore</span>
        <h3>Lifestyle Medicine Library</h3>
        <p>
          Evidence-based articles on nutrition, physical activity, sleep, metabolic health,
          and more — organized by topic.
        </p>
        <a href="/lifestyle" class="btn btn-outline">Browse the Library</a>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .breadcrumb {
    font-size: 0.85rem;
    color: var(--ink-300);
    margin-bottom: 1.5rem;
  }
  .breadcrumb a { color: var(--green-300); text-decoration: none; }
  .post-count {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--green-400);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .blog-grid-section {
    background: var(--cream-100);
  }
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .blog-empty {
    display: flex;
    justify-content: center;
  }
  .blog-empty-inner {
    max-width: 560px;
    text-align: center;
    padding: 3rem 2.5rem;
  }
  .blog-empty-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: 1rem;
  }
  .blog-empty-inner h2 { margin-bottom: 0.75rem; }
  .blog-empty-inner p { color: var(--ink-500); }
  .blog-cta-inner {
    display: flex;
    gap: 3rem;
    align-items: flex-start;
    justify-content: center;
    flex-wrap: wrap;
  }
  .lifestyle-promo {
    max-width: 320px;
    padding: 2rem;
  }
  .lifestyle-promo h3 { margin-bottom: 0.5rem; }
  .lifestyle-promo p { color: var(--ink-500); font-size: 0.92rem; margin-bottom: 1.25rem; }
  @media (max-width: 860px) {
    .blog-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 540px) {
    .blog-grid { grid-template-columns: 1fr; }
  }
</style>
