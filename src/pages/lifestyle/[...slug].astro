---
import { getCollection, render } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('lifestyle');
  return entries
    .filter(entry => !entry.data.draft)
    .map(entry => ({
      params: { slug: entry.id.replace(/\.mdx?$/, '').replace(/\/index$/, '') },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const slug = entry.id.replace(/\.mdx?$/, '').replace(/\/index$/, '');
const canonicalUrl = entry.data.canonical ?? `https://www.forwardfamilymedicine.com/lifestyle/${slug}`;
---

<MainLayout
  title={entry.data.title}
  description={entry.data.description}
  canonical={canonicalUrl}
>
  <article class="prose-page">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a> <span aria-hidden="true">›</span>
        <a href="/lifestyle-medicine">Lifestyle Medicine</a> <span aria-hidden="true">›</span>
        <span>{entry.data.title}</span>
      </nav>
      <Content />
      <aside class="medical-disclaimer" aria-label="Educational disclaimer">
        <p class="disclaimer-label">Educational Disclaimer</p>
        <p>The content on this blog is for educational and informational purposes only and is not intended as medical advice, diagnosis, or treatment. Reading this post does not create a doctor-patient relationship. Always consult your physician or a qualified healthcare provider before making any changes to your health, medications, or treatment plan.</p>
      </aside>
    </div>
  </article>
</MainLayout>

<style>
  .breadcrumb {
    font-size: 0.85rem;
    color: var(--ink-300);
    margin-bottom: 2rem;
  }
  .breadcrumb a { color: var(--green-300); text-decoration: none; }
  .prose-page {
    padding: 4rem 0;
  }
  .prose-page :global(h1) { font-size: 2.25rem; margin-bottom: 1rem; color: var(--ink-900); }
  .prose-page :global(h2) { font-size: 1.6rem; margin: 2rem 0 0.75rem; color: var(--ink-900); }
  .prose-page :global(h3) { font-size: 1.2rem; margin: 1.5rem 0 0.5rem; }
  .prose-page :global(p) { margin-bottom: 1rem; line-height: 1.75; color: var(--ink-700); }
  .prose-page :global(ul), .prose-page :global(ol) { margin: 0.5rem 0 1rem 1.5rem; }
  .prose-page :global(li) { margin-bottom: 0.4rem; line-height: 1.7; color: var(--ink-700); }
  .prose-page :global(a) { color: var(--green-300); text-decoration: underline; }
  .prose-page :global(strong) { color: #222; }
  .prose-page :global(hr) { border: none; border-top: 1px solid #e5e0d8; margin: 2rem 0; }
  .prose-page :global(blockquote) { border-left: 4px solid var(--green-300); padding: 0.5rem 1.25rem; margin: 1.5rem 0; background: var(--cream-100); color: var(--ink-700); }
  .medical-disclaimer {
    margin-top: 2rem;
    padding: 1rem 1.25rem;
    background: var(--cream-100, #f7f5f0);
    border-left: 3px solid var(--green-300);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }
  .disclaimer-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--green-400);
    margin-bottom: 0.4rem;
  }
  .medical-disclaimer p:last-child {
    font-size: 0.8rem;
    color: var(--ink-400, #888);
    line-height: 1.6;
    margin-bottom: 0;
  }
</style>
