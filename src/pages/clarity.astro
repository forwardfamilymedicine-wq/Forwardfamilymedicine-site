  .clarity-hero__sidebar {
    background: var(--ink-900);
    border-radius: var(--radius);
    padding: 1.75rem;
  }
  .clarity-sidebar__label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin: 0 0 0.4rem;
  }
  .clarity-sidebar__price {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.25rem;
    line-height: 1;
  }
  .clarity-sidebar__period {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.55);
    margin: 0 0 1.25rem;
  }
  .clarity-sidebar__list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .clarity-sidebar__list li {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.45;
    padding-left: 1rem;
    position: relative;
  }
  .clarity-sidebar__list li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--green-400);
  }
  .clarity-sidebar__ctas {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .clarity-sidebar__ctas .clarity-btn { text-align: center; }

  /* ─── SECTION 2 — PROBLEM ───────────────────────────────── */
  .clarity-problem {
    background: var(--cream-100);
    padding: var(--section-pad) 0;
  }
  .clarity-problem__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }
  .clarity-problem__left .clarity-h2 { margin-top: 0.5rem; }

  .clarity-problem-card {
    border: 1px solid var(--cream-300);
    border-radius: var(--radius);
    padding: 1.4rem;
    margin-bottom: 1rem;
    background: transparent;
  }
  .clarity-problem-card:last-child { margin-bottom: 0; }
  .clarity-problem-card__label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-500);
    margin: 0 0 0.5rem;
  }
  .clarity-problem-card .clarity-h3 { margin-bottom: 0.5rem; }

  /* ─── SECTION 3 — DIFFERENTIATOR ───────────────────────── */
  .clarity-diff {
    background: var(--cream-50);
    padding: var(--section-pad) 0;
  }
  .clarity-diff__intro {
    max-width: 760px;
    margin: 0 auto 3rem;
    text-align: center;
  }
  .clarity-diff__sub {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--ink-700);
    margin: 0;
  }
  .clarity-diff__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  .clarity-diff-card {
    border: 1px solid var(--cream-200);
    border-radius: var(--radius);
    padding: 1.75rem;
    background: #fff;
    box-shadow: var(--shadow-sm);
  }
  .clarity-diff-card__num {
    display: block;
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--green-200);
    line-height: 1;
    margin-bottom: 0.75rem;
  }
  .clarity-diff-card__stat {
    font-size: 0.82rem;
    font-style: italic;
    color: var(--green-500);
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--cream-200);
  }

  /* ─── SECTION 4 — CADENCE ───────────────────────────────── */
  .clarity-cadence {
    background: var(--ink-900);
    padding: var(--section-pad) 0;
  }
  .clarity-cadence .clarity-h2 { margin-bottom: 2.5rem; }
  .clarity-cadence__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1px;
    background: rgba(255,255,255,0.08);
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: 1.5rem;
  }
  .clarity-cadence-col {
    background: var(--ink-900);
    padding: 1.5rem 1.25rem;
  }
  .clarity-cadence-col--highlight {
    background: rgba(255,255,255,0.06);
  }
  .clarity-cadence-col__title {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--green-400);
    margin: 0 0 0.4rem;
  }
  .clarity-cadence-col__h3 {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 1rem;
  }
  .clarity-cadence-col__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .clarity-cadence-col__item {
    font-size: 0.8rem;
    line-height: 1.45;
    padding-left: 1.1rem;
    position: relative;
  }
  .clarity-cadence-col__item::before {
    position: absolute;
    left: 0;
    font-size: 0.7rem;
  }
  .clarity-cadence-col__item--bright { color: rgba(255,255,255,0.9); }
  .clarity-cadence-col__item--bright::before { content: '●'; color: var(--green-400); }
  .clarity-cadence-col__item--dim { color: rgba(255,255,255,0.45); }
  .clarity-cadence-col__item--dim::before { content: '○'; color: rgba(255,255,255,0.3); }

  .clarity-cadence__footer {
    background: rgba(255,255,255,0.05);
    border-radius: var(--radius-sm);
    padding: 1rem 1.5rem;
    font-size: 0.85rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.65);
    text-align: center;
  }

  /* ─── SECTION 5 — ANCHOR BIOMARKERS ────────────────────── */
  .clarity-anchors {
    background: var(--cream-50);
    padding: var(--section-pad) 0;
  }
  .clarity-anchors__intro {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--ink-700);
    max-width: 700px;
    margin: 0 0 2.5rem;
  }
  .clarity-anchors__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.25rem;
  }
  .clarity-anchor-card {
    border: 1px solid var(--cream-200);
    border-radius: var(--radius);
    padding: 1.5rem;
    background: #fff;
    box-shadow: var(--shadow-sm);
  }
  .clarity-anchor-card__marker {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--green-500);
    margin: 0 0 0.4rem;
    line-height: 1.1;
  }
  .clarity-anchor-card .clarity-h3 {
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }
  .clarity-anchor-card .clarity-body { font-size: 0.83rem; }
  .clarity-anchor-card__target {
    margin-top: 0.75rem;
    padding: 0.6rem 0.75rem;
    background: var(--cream-100);
    border-radius: var(--radius-sm);
    font-size: 0.78rem;
    line-height: 1.5;
    color: var(--ink-700);
  }
  .clarity-anchor-card__target-label {
    display: block;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--green-500);
    margin-bottom: 0.25rem;
  }

  /* ─── SECTION 6 — LAB DRAWS ────────────────────────────── */
  .clarity-draws {
    background: var(--ink-900);
    padding: var(--section-pad) 0;
  }
  .clarity-draws__intro {
    font-size: 0.95rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.65);
    max-width: 720px;
    margin: 0 0 2.5rem;
  }
  .clarity-draws__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .clarity-draw-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--radius);
    padding: 1.5rem;
  }
  .clarity-draw-card--tinted {
    background: rgba(63,99,68,0.18);
    border-color: rgba(63,99,68,0.35);
  }
  .clarity-draw-card__meta {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--green-400);
    margin: 0 0 0.4rem;
  }
  .clarity-draw-card .clarity-h3--white { font-size: 1rem; margin-bottom: 0.75rem; }
  .clarity-draw-card__quote {
    font-size: 0.83rem;
    font-style: italic;
    line-height: 1.6;
    color: rgba(255,255,255,0.6);
    margin: 0 0 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  .clarity-draw-category { margin-bottom: 0.9rem; }
  .clarity-draw-category__label {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin: 0 0 0.25rem;
  }
  .clarity-draw-category__desc {
    font-size: 0.82rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.7);
    margin: 0;
  }
  .clarity-draw-note {
    font-size: 0.8rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.45);
    font-style: italic;
    padding: 0.75rem;
    border: 1px dashed rgba(255,255,255,0.15);
    border-radius: var(--radius-sm);
    margin-top: 0.5rem;
  }
  .clarity-draw-card__addl {
    font-size: 0.82rem;
    font-style: italic;
    color: var(--green-300);
    margin: 0.5rem 0 0;
  }

  .clarity-draws__renewal {
    background: rgba(63,99,68,0.15);
    border: 1px solid rgba(63,99,68,0.3);
    border-radius: var(--radius);
    padding: 2rem;
  }
  .clarity-draws__renewal-grid {
    display: grid;
    grid-template-columns: 180px 1fr 1fr;
    gap: 2rem;
    align-items: start;
  }
  .clarity-draws__renewal-eyebrow {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--green-400);
    margin: 0 0 0.3rem;
  }
  .clarity-draws__renewal-title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.2rem;
  }
  .clarity-draws__renewal-meta {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.55);
    margin: 0 0 0.15rem;
  }
  .clarity-draws__renewal-sub {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.4);
    margin: 0;
  }
  .clarity-draws__renewal-label {
    font-size: 0.75rem;
    font-weight: 700;
    color: rgba(255,255,255,0.7);
    margin: 0 0 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .clarity-draws__renewal-note {
    font-size: 0.8rem;
    font-style: italic;
    color: rgba(255,255,255,0.45);
    margin: 0.5rem 0 0;
  }
  .clarity-draws__renewal-small {
    font-size: 0.78rem;
    font-style: italic;
    color: rgba(255,255,255,0.4);
    margin: 0.5rem 0 0;
  }

  /* ─── SECTION 7 — PREMIUM MARKERS ──────────────────────── */
  .clarity-markers {
    background: var(--cream-100);
    padding: var(--section-pad) 0;
  }
  .clarity-markers__intro {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--ink-700);
    max-width: 680px;
    margin: 0 0 2.5rem;
  }
  .clarity-markers__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  .clarity-marker-card {
    background: #fff;
    border: 1px solid var(--cream-200);
    border-radius: var(--radius);
    padding: 1.5rem;
    box-shadow: var(--shadow-sm);
  }
  .clarity-marker-card__badge {
    display: inline-block;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
    margin-bottom: 0.75rem;
  }
  .clarity-marker-card__badge--cardio { background: var(--warm-100); color: #8C6D3F; }
  .clarity-marker-card__badge--metabolic { background: var(--green-50); color: var(--green-500); }
  .clarity-marker-card__badge--performance { background: var(--cream-200); color: var(--ink-700); }
  .clarity-marker-card__badge--kidney { background: var(--cream-100); color: var(--ink-500); }
  .clarity-marker-card__badge--optin { background: var(--ink-50); color: var(--ink-700); }
  .clarity-marker-card__badge--inflammation { background: var(--green-100); color: var(--green-500); }

  .clarity-marker-card__tagline {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--ink-900);
    margin: 0 0 0.5rem;
    line-height: 1.4;
  }
  .clarity-marker-card .clarity-body { font-size: 0.875rem; }
  .clarity-marker-card__note {
    font-size: 0.78rem;
    font-style: italic;
    color: var(--ink-500);
    margin: 0.5rem 0 0;
    padding-top: 0.5rem;
    border-top: 1px solid var(--cream-200);
  }

  /* ─── SECTION 8 — OUTCOMES ──────────────────────────────── */
  .clarity-outcomes {
    background: var(--cream-100);
    padding: var(--section-pad) 0;
  }
  .clarity-outcomes__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 2rem;
  }
  .clarity-outcome-item__bar {
    width: 32px;
    height: 2px;
    background: var(--green-500);
    margin-bottom: 1rem;
  }
  .clarity-outcome-item .clarity-h3 { margin-bottom: 0.5rem; }

  /* ─── SECTION 9 — LIFESTYLE FIRST ──────────────────────── */
  .clarity-lifestyle {
    background: var(--cream-100);
    padding: var(--section-pad) 0;
  }
  .clarity-lifestyle__intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
    margin-bottom: 2.5rem;
  }
  .clarity-lifestyle__right .clarity-body + .clarity-body { margin-top: 0.75rem; }
  .clarity-lifestyle__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .clarity-lifestyle-card {
    border: 1px solid var(--cream-300);
    border-radius: var(--radius);
    padding: 1.5rem;
    background: var(--cream-50);
  }
  .clarity-lifestyle-card__bar {
    width: 32px;
    height: 2px;
    background: var(--green-500);
    margin-bottom: 1rem;
  }

  /* ─── SECTION 10 — WHO IT'S FOR ─────────────────────────── */
  .clarity-who {
    background: var(--cream-50);
    padding: var(--section-pad) 0;
  }
  .clarity-who__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }
  .clarity-who__list {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .clarity-who__list li {
    font-size: 0.93rem;
    line-height: 1.6;
    color: var(--ink-700);
    display: flex;
    gap: 0.6rem;
  }
  .clarity-who__arrow {
    color: var(--green-500);
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }
  .clarity-who__x {
    color: #c0856a;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }
  .clarity-who__callout {
    margin-top: 1.5rem;
    background: var(--cream-100);
    border: 1px solid var(--cream-300);
    border-radius: var(--radius);
    padding: 1.1rem 1.25rem;
    font-size: 0.88rem;
    color: var(--ink-700);
    line-height: 1.6;
  }
  .clarity-who__callout p { margin: 0 0 0.5rem; }
  .clarity-who__callout-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--green-500);
    text-decoration: none;
  }
  .clarity-who__callout-link:hover { color: #3D6B55; }

  /* ─── SECTION 11 — PRICING ──────────────────────────────── */
  .clarity-pricing {
    background: var(--cream-100);
    padding: var(--section-pad) 0;
  }
  .clarity-pricing__intro {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--ink-700);
    max-width: 680px;
    margin: 0 0 2.5rem;
  }
  .clarity-pricing__compare {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }
  .clarity-compare-card {
    background: #fff;
    border: 1px solid var(--cream-200);
    border-radius: var(--radius);
    padding: 1.5rem;
    box-shadow: var(--shadow-sm);
  }
  .clarity-compare-card .clarity-h3 { font-size: 1.05rem; margin-bottom: 0.2rem; }
  .clarity-compare-card__sub {
    font-size: 0.72rem;
    color: var(--ink-500);
    margin: 0 0 0.75rem;
  }
  .clarity-compare-card__quote {
    font-size: 0.82rem;
    font-style: italic;
    color: var(--ink-500);
    margin: 0.75rem 0 0;
    padding-top: 0.75rem;
    border-top: 1px solid var(--cream-200);
  }
  .clarity-pricing__box {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    background: #fff;
    border: 1px solid var(--cream-300);
    border-radius: var(--radius);
    padding: 2rem 2.5rem;
    align-items: center;
    box-shadow: var(--shadow-sm);
  }
  .clarity-pricing__price {
    font-family: var(--font-heading);
    font-size: 3rem;
    font-weight: 700;
    color: var(--ink-900);
    margin: 0 0 0.25rem;
    line-height: 1;
  }
  .clarity-pricing__period {
    font-size: 0.85rem;
    color: var(--ink-500);
    margin: 0;
  }
  .clarity-pricing__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.25rem;
  }
  .clarity-pricing__tag {
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.25rem 0.6rem;
    background: var(--cream-100);
    border: 1px solid var(--cream-300);
    border-radius: 4px;
    color: var(--ink-700);
  }
  .clarity-pricing__ctas {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
  }

  /* ─── SECTION 12 — PROMISE ──────────────────────────────── */
  .clarity-promise {
    background: var(--ink-900);
    padding: var(--section-pad) 0;
  }
  .clarity-promise__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .clarity-promise__quote {
    font-family: var(--font-heading);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    font-style: italic;
    color: rgba(255,255,255,0.85);
    line-height: 1.65;
    margin: 0 0 1.25rem;
  }
  .clarity-promise__body {
    font-size: 0.93rem;
    line-height: 1.75;
    color: rgba(255,255,255,0.6);
    margin: 0;
  }

  /* Section 13 uses the shared FAQSection component — no page-level FAQ styles needed */

  /* ─── SECTION 14 — CLOSE CTA ────────────────────────────── */
  .clarity-close {
    background: var(--ink-900);
    padding: var(--section-pad) 0;
  }
  .clarity-close__inner {
    text-align: center;
    max-width: 640px;
  }
  .clarity-close__sub {
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.65);
    margin: 0 0 2rem;
  }
  .clarity-close__alt {
    margin: 1.25rem 0 0;
  }
  .clarity-close__alt-link {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
  }
  .clarity-close__alt-link:hover { color: rgba(255,255,255,0.8); }

  /* ─── RESPONSIVE ────────────────────────────────────────── */
  @media (max-width: 1100px) {
    .clarity-anchors__grid { grid-template-columns: repeat(3, 1fr); }
    .clarity-cadence__grid { grid-template-columns: repeat(3, 1fr); }
    .clarity-draws__grid { grid-template-columns: repeat(2, 1fr); }
    .clarity-draws__renewal-grid { grid-template-columns: 1fr 1fr; }
    .clarity-draws__renewal-grid > :first-child { grid-column: 1 / -1; }
  }

  @media (max-width: 900px) {
    .clarity-hero__grid { grid-template-columns: 1fr; }
    .clarity-hero__sidebar { max-width: 400px; }
    .clarity-problem__grid { grid-template-columns: 1fr; }
    .clarity-diff__grid { grid-template-columns: 1fr; }
    .clarity-anchors__grid { grid-template-columns: repeat(2, 1fr); }
    .clarity-cadence__grid { grid-template-columns: repeat(2, 1fr); }
    .clarity-outcomes__grid { grid-template-columns: repeat(2, 1fr); }
    .clarity-lifestyle__intro-grid { grid-template-columns: 1fr; gap: 1.5rem; }
    .clarity-lifestyle__cards { grid-template-columns: 1fr; }
