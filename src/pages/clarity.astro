---
import MainLayout from '../layouts/MainLayout.astro';
import FAQSection from '../components/shared/FAQSection.astro';
import BotanicalGraphic from '../components/shared/BotanicalGraphic.astro';

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.forwardfamilymedicine.com" },
    { "@type": "ListItem", "position": 2, "name": "The Clarity Program", "item": "https://www.forwardfamilymedicine.com/clarity/" }
  ]
};

const claritySchema = {
  "@context": "https://schema.org",
  "@type": "MedicalClinic",
  "name": "The Clarity Program — Forward Family Medicine",
  "description": "A physician-led longitudinal health operating system for the Main Line. Prenuvo whole-body MRI, advanced biomarker panels, DEXA, VO₂ max, CGM, and gut microbiome — with physician interpretation at every step. $9,600/year.",
  "url": "https://www.forwardfamilymedicine.com/clarity/",
  "telephone": "+12156457044",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "295 Old Eagle School Road",
    "addressLocality": "Wayne",
    "addressRegion": "PA",
    "postalCode": "19087",
    "addressCountry": "US"
  },
  "areaServed": [
    { "@type": "City", "name": "Wayne, PA" },
    { "@type": "AdministrativeArea", "name": "Philadelphia Main Line" },
    { "@type": "City", "name": "Philadelphia, PA" }
  ],
  "medicalSpecialty": ["FamilyMedicine", "PreventiveMedicine"]
};

const faqs = [
  {
    q: 'Is this in addition to a standard FFM membership?',
    a: 'No. The Clarity Program includes your full FFM membership. One annual fee, paid upfront, covers everything — advanced diagnostics and standard DPC access alike. There is no monthly payment option.',
  },
  {
    q: 'Do I need to be an existing FFM patient?',
    a: 'No. You can join directly. Your enrollment appointment is the introduction — we build your health picture from the ground up at that first visit.',
  },
  {
    q: 'Who interprets the imaging and labs?',
    a: 'Prenuvo provides board-certified radiologist reports. Dr. Bigley reviews all results with you directly, connects them to your full clinical picture, and coordinates any follow-through.',
  },
  {
    q: 'Where does testing take place?',
    a: 'Prenuvo is 0.5 miles from our Wayne office. DEXA and VO₂ max testing take place at partner facilities nearby. Lab draws occur at LabCorp locations or can be coordinated in-office. We handle scheduling and all referrals.',
  },
  {
    q: 'What if something is found?',
    a: "That's exactly what the physician relationship is for. We coordinate follow-up directly — calling ahead to specialists, providing clinical context, and ensuring nothing falls through the gap between a result and a plan.",
  },
  {
    q: 'Can I use my HSA?',
    a: 'The membership component is HSA-eligible following the Primary Care Enhancement Act (effective January 1, 2026). For imaging and testing components, confirm with your plan administrator.',
  },
  {
    q: "Why does Clarity's lab program feel different from consumer testing platforms?",
    a: "Consumer platforms are built around biomarker volume. Clarity is built around physician interpretation and longitudinal tracking. Across your four draws per year you'll receive nearly 250 individual results — but every one connects to a clinical question, a trend line, and a physician who tells you exactly what it means and what we're doing about it.",
  },
  {
    q: 'Why is the Month 3 panel smaller than Month 6?',
    a: "Month 3's job is to confirm your interventions are working and safe — early treatment response and medication safety checks. Vitamin D, Omega-3 Index, and NMR particle scores haven't had enough time to meaningfully move at 90 days. We run those at Month 6 when there's real signal to measure.",
  },
  {
    q: 'Why measure Lipoprotein(a) only once?',
    a: "Lp(a) is approximately 90% genetic. Your number was set at conception and doesn't change meaningfully through life. We measure it once to know it forever, and calibrate your cardiovascular plan around it.",
  },
  {
    q: 'Why only check Vitamin D two or three times a year?',
    a: 'Vitamin D has a 3-week half-life and takes 8–12 weeks to stabilize after a dose change. Testing it every 3 months is expensive noise. We time your draws seasonally to capture your real year-round pattern.',
  },
  {
    q: 'What does physician-interpreted actually mean in practice?',
    a: 'Your Clarity physician reviews every result before it reaches you. Your baseline draw delivers 85+ individual results. Each follow-up adds 43 to 63 more — reviewed in context of every prior draw, with a clear narrative and a specific plan attached to every result.',
  },
  {
    q: 'Is this an annual program? What happens at 12 months?',
    a: 'Yes — Clarity is an annual program paid upfront. Your program runs from enrollment through Month 9, where you receive your 12-month health blueprint and have a renewal conversation. If you renew, Year 2 begins with a full re-enrollment draw — everything from Month 0 except the one-time lifetime markers, which are already in your record permanently.',
  },
];
---

<MainLayout
  title="The Clarity Program | Executive Health | Forward Family Medicine Wayne PA"
  description="A physician-led longitudinal health operating system for the Main Line. Prenuvo whole-body MRI, advanced biomarker panels, DEXA, VO₂ max, CGM, and gut microbiome — with physician interpretation at every step. $9,600/year."
  canonical="/clarity/"
  schema={[breadcrumb, claritySchema]}
>
  <div class="clarity-page">

    <!-- SECTION 1 — HERO -->
    <section class="clarity-hero">
      <BotanicalGraphic variant="layered" class="clarity-botanical" />
      <div class="clarity-container clarity-hero__grid">
        <div class="clarity-hero__text">
          <p class="clarity-eyebrow">The Clarity Program · Forward Family Medicine</p>
          <h1 class="clarity-hero__h1">Your health needs a system, not a schedule.</h1>
          <p class="clarity-hero__sub">The Clarity Program is a physician-led longitudinal health operating system — continuous monitoring, structured diagnostics, and a physician who reads everything together, tracks how it changes over time, and acts on what it finds. Not a one-time event. Not a dashboard. A system running on your behalf, all year.</p>
          <div class="clarity-hero__ctas">
            <a href="/new-patients/?source=clarity" class="clarity-btn clarity-btn--dark">Schedule an inquiry call</a>
            <a href="#how" class="clarity-btn clarity-btn--ghost-dark">See how it works →</a>
          </div>
        </div>
        <div class="clarity-hero__sidebar">
          <p class="clarity-sidebar__label">Annual membership</p>
          <p class="clarity-sidebar__price">$9,600</p>
          <p class="clarity-sidebar__period">Paid annually · HSA-eligible</p>
          <ul class="clarity-sidebar__list">
            <li>Prenuvo whole-body MRI at enrollment</li>
            <li>4 advanced biomarker draws — 85–63 results each</li>
            <li>Gut microbiome panel at enrollment</li>
            <li>6 weeks CGM monitoring across the year</li>
            <li>DEXA body composition, 2×/year</li>
            <li>VO₂ max testing, 2×/year</li>
            <li>Coronary calcium score, every 3 years</li>
            <li>Full FFM membership included</li>
          </ul>
          <div class="clarity-sidebar__ctas">
            <a href="/new-patients/?source=clarity" class="clarity-btn clarity-btn--green">Schedule an inquiry call</a>
            <a href="#how" class="clarity-btn clarity-btn--ghost-light">See what's included →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 2 — PROBLEM -->
    <section class="clarity-problem">
      <div class="clarity-container clarity-problem__grid">
        <div class="clarity-problem__left">
          <p class="clarity-eyebrow">Why typical care falls short</p>
          <h2 class="clarity-h2">The problem isn't access to data. It's that nothing connects.</h2>
          <p class="clarity-body">You've probably pieced together a health routine that's better than most. But piecing things together is the problem. When your physician, your labs, your imaging, your CGM, and your fitness data don't connect — and no one is accountable for reading them as a system — you're not getting a picture. You're getting fragments.</p>
        </div>
        <div class="clarity-problem__right">
          <div class="clarity-problem-card">
            <p class="clarity-problem-card__label">Executive physicals</p>
            <h3 class="clarity-h3">A full day of testing. Then silence for twelve months.</h3>
            <p class="clarity-body">Valuable data, no follow-through. A results binder doesn't adjust your protocol when your biomarkers shift. A physician who knows your history does.</p>
          </div>
          <div class="clarity-problem-card">
            <p class="clarity-problem-card__label">DIY testing platforms</p>
            <h3 class="clarity-h3">160 biomarkers and a dashboard. But no one to call.</h3>
            <p class="clarity-body">Function Health, InsideTracker, and similar services surface data efficiently. Without clinical interpretation, a number outside the reference range produces anxiety, not action.</p>
          </div>
          <div class="clarity-problem-card">
            <p class="clarity-problem-card__label">Traditional primary care</p>
            <h3 class="clarity-h3">Twenty minutes a year with a doctor you rarely see.</h3>
            <p class="clarity-body">A physician seeing 25 patients a day cannot read your VO₂ trends, review your imaging, and connect it to your bloodwork. The structure of standard care makes that impossible.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 3 — DIFFERENTIATOR -->
    <section class="clarity-diff">
      <div class="clarity-container">
        <div class="clarity-diff__intro">
          <p class="clarity-eyebrow">What makes this different</p>
          <h2 class="clarity-h2">Four inputs. One operating system. One physician accountable for all of it.</h2>
          <p class="clarity-diff__sub">The Clarity Program isn't a menu of diagnostics. It's a closed-loop system — each data source is read in the context of the others, by the same physician, across time. That's what turns measurement into medicine.</p>
        </div>
        <div class="clarity-diff__grid">
          <div class="clarity-diff-card">
            <span class="clarity-diff-card__num">01</span>
            <h3 class="clarity-h3">Structural imaging — what bloodwork cannot see</h3>
            <p class="clarity-body">The Prenuvo whole-body MRI screens 500+ conditions across 33 organ systems — brain, spine, organs, vasculature — before symptoms appear. Dr. Bigley reviews findings with you directly and coordinates any follow-through. This is the only input that reveals what's structurally happening inside your body right now.</p>
            <p class="clarity-diff-card__stat">14% of first-time Prenuvo members discover a clinically significant finding they didn't know existed.</p>
          </div>
          <div class="clarity-diff-card">
            <span class="clarity-diff-card__num">02</span>
            <h3 class="clarity-h3">Biomarkers and gut health — interpreted in context, four times a year</h3>
            <p class="clarity-body">Over 60 blood markers across cardiovascular risk, hormones, metabolic health, inflammation, and organ function — reviewed at enrollment, month 3, and month 9. Paired with a gut microbiome panel at enrollment that maps your bacterial diversity, inflammatory species, and digestive function.</p>
            <p class="clarity-diff-card__stat">CGM data is read alongside bloodwork at each check-in — real-time glucose and bloodwork together tell a far more complete metabolic story.</p>
          </div>
          <div class="clarity-diff-card">
            <span class="clarity-diff-card__num">03</span>
            <h3 class="clarity-h3">Continuous glucose monitoring — metabolic data between visits</h3>
            <p class="clarity-body">Six weeks of CGM data distributed across three 2-week windows, timed to align with your lab check-ins. While bloodwork captures a single moment, CGM tracks how your glucose actually behaves — across meals, sleep, stress, and exercise — over days.</p>
            <p class="clarity-diff-card__stat">Insulin resistance is detectable by CGM years before it appears on standard diabetes screening.</p>
          </div>
          <div class="clarity-diff-card">
            <span class="clarity-diff-card__num">04</span>
            <h3 class="clarity-h3">Physical performance — measured as a clinical vital sign</h3>
            <p class="clarity-body">VO₂ max is the strongest independent predictor of all-cause mortality in the medical literature — stronger than blood pressure, cholesterol, or smoking status. DEXA body composition tracks lean mass, visceral fat, and bone density with the precision BMI was never designed to provide. Both tested twice yearly.</p>
            <p class="clarity-diff-card__stat">Cardiorespiratory fitness is more predictive of longevity than any single biomarker we measure.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 4 — CADENCE -->
    <section class="clarity-cadence" id="how">
      <div class="clarity-container">
        <p class="clarity-eyebrow clarity-eyebrow--green">How the operating system runs</p>
        <h2 class="clarity-h2 clarity-h2--white">Four structured milestones. Continuous monitoring between them.</h2>
        <div class="clarity-cadence__grid">

          <div class="clarity-cadence-col clarity-cadence-col--highlight">
            <p class="clarity-cadence-col__title">Month 0 — Enrollment</p>
            <h3 class="clarity-cadence-col__h3">Foundation</h3>
            <ul class="clarity-cadence-col__list">
              <li class="clarity-cadence-col__item clarity-cadence-col__item--bright">3-hour new patient visit</li>
              <li class="clarity-cadence-col__item clarity-cadence-col__item--bright">Prenuvo whole-body MRI</li>
              <li class="clarity-cadence-col__item clarity-cadence-col__item--bright">Full biomarker panel (~85 results)</li>
              <li class="clarity-cadence-col__item clarity-cadence-col__item--bright">Gut microbiome panel</li>
              <li class="clarity-cadence-col__item clarity-cadence-col__item--bright">2-week CGM baseline period</li>
              <li class="clarity-cadence-col__item clarity-cadence-col__item--bright">DEXA body composition</li>
              <li class="clarity-cadence-col__item clarity-cadence-col__item--bright">VO₂ max baseline</li>
              <li class="clarity-cadence-col__item clarity-cadence-col__item--dim">Coronary calcium score if due</li>
            </ul>
          </div>

          <div class="clarity-cadence-col">
            <p class="clarity-cadence-col__title">Month 3</p>
            <h3 class="clarity-cadence-col__h3">Response check</h3>
            <ul class="clarity-cadence-col__list">
              <li class="clarity-cadence-col__item clarity-cadence-col__item--bright">2-week CGM period</li>
              <li class="clarity-cadence-col__item clarity-cadence-col__item--bright">Lab check-in (~43 results)</li>
              <li class="clarity-cadence-col__item clarity-cadence-col__item--dim">Intervention response confirmed</li>
              <li class="clarity-cadence-col__item clarity-cadence-col__item--dim">Medication safety reviewed</li>
              <li class="clarity-cadence-col__item clarity-cadence-col__item--bright">Physician review visit</li>
            </ul>
          </div>

          <div class="clarity-cadence-col">
            <p class="clarity-cadence-col__title">Month 6</p>
            <h3 class="clarity-cadence-col__h3">Semi-annual expansion</h3>
            <ul class="clarity-cadence-col__list">
              <li class="clarity-cadence-col__item clarity-cadence-col__item--bright">DEXA — second scan</li>
              <li class="clarity-cadence-col__item clarity-cadence-col__item--bright">VO₂ max — follow-up test</li>
              <li class="clarity-cadence-col__item clarity-cadence-col__item--bright">Lab check-in (~63 results)</li>
              <li class="clarity-cadence-col__item clarity-cadence-col__item--dim">Body comp vs. baseline</li>
              <li class="clarity-cadence-col__item clarity-cadence-col__item--bright">Physician review visit</li>
            </ul>
          </div>

          <div class="clarity-cadence-col clarity-cadence-col--highlight">
            <p class="clarity-cadence-col__title">Month 9</p>
            <h3 class="clarity-cadence-col__h3">Drift check</h3>
            <ul class="clarity-cadence-col__list">
              <li class="clarity-cadence-col__item clarity-cadence-col__item--bright">2-week CGM period</li>
              <li class="clarity-cadence-col__item clarity-cadence-col__item--bright">Lab check-in (~55 results)</li>
              <li class="clarity-cadence-col__item clarity-cadence-col__item--dim">CGM + bloodwork read together</li>
              <li class="clarity-cadence-col__item clarity-cadence-col__item--bright">Physician review visit</li>
              <li class="clarity-cadence-col__item clarity-cadence-col__item--bright">12-month health blueprint</li>
              <li class="clarity-cadence-col__item clarity-cadence-col__item--bright">Year 2 renewal conversation</li>
            </ul>
          </div>

          <div class="clarity-cadence-col">
            <p class="clarity-cadence-col__title">Upon renewal</p>
            <h3 class="clarity-cadence-col__h3">Year 2 begins</h3>
            <ul class="clarity-cadence-col__list">
              <li class="clarity-cadence-col__item clarity-cadence-col__item--bright">Prenuvo MRI — repeated</li>
              <li class="clarity-cadence-col__item clarity-cadence-col__item--bright">Full lab draw (~80+ results)</li>
              <li class="clarity-cadence-col__item clarity-cadence-col__item--bright">Gut microbiome — repeated</li>
              <li class="clarity-cadence-col__item clarity-cadence-col__item--bright">DEXA + VO₂ max baseline</li>
              <li class="clarity-cadence-col__item clarity-cadence-col__item--bright">2-week CGM baseline</li>
              <li class="clarity-cadence-col__item clarity-cadence-col__item--dim">One-time markers excluded — already in your record</li>
            </ul>
          </div>

        </div>
        <div class="clarity-cadence__footer">
          Between every milestone: unlimited same-day visits, direct physician contact, specialist coordination, in-office procedures, and wholesale medications — included in your membership.
        </div>
      </div>
    </section>

    <!-- SECTION 5 — ANCHOR BIOMARKERS -->
    <section class="clarity-anchors">
      <div class="clarity-container">
        <p class="clarity-eyebrow">The numbers that matter most</p>
        <h2 class="clarity-h2">Five anchor biomarkers. Tracked at every draw, trended every year.</h2>
        <p class="clarity-anchors__intro">These are your longitudinal health record — the first numbers your physician reviews at every visit, with trend context from every prior draw in your program.</p>
        <div class="clarity-anchors__grid">

          <div class="clarity-anchor-card">
            <p class="clarity-anchor-card__marker">ApoB</p>
            <h3 class="clarity-h3">The atherogenic particle count</h3>
            <p class="clarity-body">More accurate than cholesterol. Counts every particle capable of causing arterial disease — this is the number we treat to, not LDL-C.</p>
            <div class="clarity-anchor-card__target">
              <span class="clarity-anchor-card__target-label">Target</span>
              &lt;80 mg/dL primary prevention / &lt;65 moderate risk / &lt;55 with ASCVD or elevated Lp(a)
            </div>
          </div>

          <div class="clarity-anchor-card">
            <p class="clarity-anchor-card__marker">Fasting Insulin</p>
            <h3 class="clarity-h3">The metabolic early-warning system</h3>
            <p class="clarity-body">Detects insulin resistance 5–10 years before HbA1c moves. The single biggest early-detection delta between Clarity and standard primary care.</p>
            <div class="clarity-anchor-card__target">
              <span class="clarity-anchor-card__target-label">Target</span>
              &lt;8 µIU/mL / HOMA-IR &lt;1.5
            </div>
          </div>

          <div class="clarity-anchor-card">
            <p class="clarity-anchor-card__marker">HbA1c</p>
            <h3 class="clarity-h3">Your 3-month blood sugar memory</h3>
            <p class="clarity-body">A rolling average of glucose control over 90 days — held to a tighter standard than conventional medicine considers normal.</p>
            <div class="clarity-anchor-card__target">
              <span class="clarity-anchor-card__target-label">Target</span>
              &lt;5.4% (stricter than ADA "normal")
            </div>
          </div>

          <div class="clarity-anchor-card">
            <p class="clarity-anchor-card__marker">hs-CRP</p>
            <h3 class="clarity-h3">The whole-body inflammation thermostat</h3>
            <p class="clarity-body">Chronic low-grade inflammation is the shared mechanism behind cardiovascular disease, cognitive decline, and accelerated aging.</p>
            <div class="clarity-anchor-card__target">
              <span class="clarity-anchor-card__target-label">Target</span>
              &lt;1.0 mg/L
            </div>
          </div>

          <div class="clarity-anchor-card">
            <p class="clarity-anchor-card__marker">Vitamin D</p>
            <h3 class="clarity-h3">The nutrient with the highest response-to-intervention ratio</h3>
            <p class="clarity-body">Almost everyone can move this number meaningfully within 90 days. Tested at seasonal intervals — not quarterly, when it's mostly noise.</p>
            <div class="clarity-anchor-card__target">
              <span class="clarity-anchor-card__target-label">Target</span>
              40–60 ng/mL
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- SECTION 6 — LAB DRAWS -->
    <section class="clarity-draws">
      <div class="clarity-container">
        <p class="clarity-eyebrow clarity-eyebrow--green">The 12-month draw cadence</p>
        <h2 class="clarity-h2 clarity-h2--white">Timed to biology, not the calendar.</h2>
        <p class="clarity-draws__intro">Each draw is purposeful — every result answers a specific clinical question, and every number your physician reviews has a clear 'because of this, we will…' attached. Across your first year, that's nearly 250 individual biomarker results — with physician interpretation on every one.</p>

        <div class="clarity-draws__grid">

          <div class="clarity-draw-card clarity-draw-card--tinted">
            <div class="clarity-draw-card__header">
              <p class="clarity-draw-card__meta">~85+ results · One-time lifetime markers · Prenuvo MRI</p>
              <h3 class="clarity-h3 clarity-h3--white">Month 0 Baseline</h3>
              <p class="clarity-draw-card__quote">Your comprehensive enrollment visit. Every longitudinal reference point for your Clarity program, your Prenuvo whole-body MRI, gut microbiome baseline, and the lifetime genetic markers you'll know forever — all at the start.</p>
            </div>
            <div class="clarity-draw-card__categories">
              <div class="clarity-draw-category">
                <p class="clarity-draw-category__label">Metabolic &amp; Organ Reserve</p>
                <p class="clarity-draw-category__desc">A comprehensive window into how your liver, kidneys, blood, and blood sugar are performing — including markers most panels skip that predict metabolic risk years before disease appears.</p>
              </div>
              <div class="clarity-draw-category">
                <p class="clarity-draw-category__label">Advanced Cardiovascular</p>
                <p class="clarity-draw-category__desc">Beyond standard cholesterol — particle counts, atherogenic particle burden, inflammation markers, and a one-time genetic cardiovascular risk marker that most physicians have never ordered.</p>
              </div>
              <div class="clarity-draw-category">
                <p class="clarity-draw-category__label">Hormones</p>
                <p class="clarity-draw-category__desc">A complete hormonal baseline — thyroid (including active and inactive forms), sex hormones with gold-standard assay methodology, adrenal markers, and growth factors. Tailored by sex and age.</p>
              </div>
              <div class="clarity-draw-category">
                <p class="clarity-draw-category__label">Nutritional Status</p>
                <p class="clarity-draw-category__desc">Key micronutrients that affect energy, immune function, cardiovascular risk, and cognitive performance — measured at levels optimized for performance, not just above the clinical floor.</p>
              </div>
              <div class="clarity-draw-category">
                <p class="clarity-draw-category__label">One-Time Genetic Markers</p>
                <p class="clarity-draw-category__desc">Blood typing and an optional cardiovascular and cognitive risk genotype — measured once, known forever.</p>
              </div>
            </div>
          </div>

          <div class="clarity-draw-card">
            <div class="clarity-draw-card__header">
              <p class="clarity-draw-card__meta">~43 results · Intervention and safety focus</p>
              <h3 class="clarity-h3 clarity-h3--white">Month 3 Response check</h3>
              <p class="clarity-draw-card__quote">Ninety days is the ideal window to answer: is what we started working, and is it safe? Every result here is time-sensitive.</p>
            </div>
            <div class="clarity-draw-card__categories">
              <div class="clarity-draw-category">
                <p class="clarity-draw-category__label">What We're Checking</p>
                <p class="clarity-draw-category__desc">Metabolic response to any interventions started at enrollment. Cardiovascular markers confirming treatment targets are moving. Organ safety. Blood sugar trajectory at the first meaningful checkpoint.</p>
              </div>
              <div class="clarity-draw-note">
                Nutritional markers and advanced lipid particle counts are intentionally held until Month 6 — they require more time to reflect real change. Testing them at 90 days produces noise, not signal.
              </div>
            </div>
          </div>

          <div class="clarity-draw-card">
            <div class="clarity-draw-card__header">
              <p class="clarity-draw-card__meta">~63 results · Richest mid-year draw</p>
              <h3 class="clarity-h3 clarity-h3--white">Month 6 Semi-annual expansion</h3>
              <p class="clarity-draw-card__quote">The most comprehensive follow-up draw of the year. Slow-turnover markers have finally stabilized enough to be meaningful.</p>
            </div>
            <div class="clarity-draw-card__categories">
              <div class="clarity-draw-category">
                <p class="clarity-draw-category__label">What We're Checking</p>
                <p class="clarity-draw-category__desc">Full cardiovascular panel including advanced particle analysis. Metabolic markers with trend context from Month 3. Nutritional status — particularly Vitamin D timed to seasonal low and Omega-3 index which requires 120 days to reflect dietary changes.</p>
              </div>
              <p class="clarity-draw-card__addl">Hormone panel added for members on active therapy or with Month 0 abnormals being treated.</p>
            </div>
          </div>

          <div class="clarity-draw-card">
            <div class="clarity-draw-card__header">
              <p class="clarity-draw-card__meta">~55 results · Pre-annual trajectory lock</p>
              <h3 class="clarity-h3 clarity-h3--white">Month 9 Drift check</h3>
              <p class="clarity-draw-card__quote">A focused pre-annual checkpoint. We confirm the trajectory from Month 6 holds, catch any drift, and adjust anything heading in the wrong direction.</p>
            </div>
            <div class="clarity-draw-card__categories">
              <div class="clarity-draw-category">
                <p class="clarity-draw-category__label">What We're Checking</p>
                <p class="clarity-draw-category__desc">Core metabolic and cardiovascular markers with three-draw trend context. Advanced lipid particle analysis. Organ function and inflammation. Additional markers added on clinical indication — nothing routine that hasn't earned its place by this point.</p>
              </div>
            </div>
          </div>

        </div>

        <div class="clarity-draws__renewal">
          <div class="clarity-draws__renewal-grid">
            <div class="clarity-draws__renewal-col">
              <p class="clarity-draws__renewal-eyebrow">Upon renewal</p>
              <p class="clarity-draws__renewal-title">Year 2 enrollment</p>
              <p class="clarity-draws__renewal-meta">~80+ results</p>
              <p class="clarity-draws__renewal-sub">Year 2 begins</p>
            </div>
            <div class="clarity-draws__renewal-col">
              <p class="clarity-draws__renewal-label">The renewal draw — everything from Month 0, minus what's already known</p>
              <p class="clarity-body clarity-body--muted">Renewing members start Year 2 with a full enrollment draw — Prenuvo MRI, comprehensive labs, gut microbiome, DEXA, VO₂ max, and CGM baseline. The difference from Year 1: the one-time lifetime markers don't need repeating. Everything else resets as a new longitudinal anchor, now read against Year 1 data.</p>
              <p class="clarity-draws__renewal-note">The 12-month health blueprint delivered at your Month 9 visit makes the case for renewal.</p>
            </div>
            <div class="clarity-draws__renewal-col">
              <p class="clarity-draws__renewal-label">Why the data compounds</p>
              <p class="clarity-body clarity-body--muted">A single year of Clarity data tells you where you are. Two years tells you which direction you're moving and how fast. The longitudinal record doesn't reset on renewal — it deepens.</p>
              <p class="clarity-draws__renewal-small">Members who renew move from establishing baselines to tracking trajectories. That shift is where the program's real diagnostic power comes from.</p>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- SECTION 7 — PREMIUM MARKERS -->
    <section class="clarity-markers">
      <div class="clarity-container">
        <p class="clarity-eyebrow">Why it's different from standard care</p>
        <h2 class="clarity-h2">The markers most physicians still don't order.</h2>
        <p class="clarity-markers__intro">Each of these represents a significant gap between what standard primary care tests and what advanced cardiovascular and metabolic medicine requires.</p>
        <div class="clarity-markers__grid">

          <div class="clarity-marker-card">
            <span class="clarity-marker-card__badge clarity-marker-card__badge--cardio">Cardiovascular</span>
            <h3 class="clarity-h3">Lipoprotein(a)</h3>
            <p class="clarity-marker-card__tagline">The genetic risk factor most doctors still miss.</p>
            <p class="clarity-body">Measured once in your lifetime. About 90% genetic. Roughly 1 in 5 adults has an elevated level that dramatically increases cardiovascular risk independent of LDL cholesterol.</p>
            <p class="clarity-marker-card__note">New targeted therapies are in late-stage trials. We measure it now so your care plan is ready when they arrive.</p>
          </div>

          <div class="clarity-marker-card">
            <span class="clarity-marker-card__badge clarity-marker-card__badge--cardio">Cardiovascular</span>
            <h3 class="clarity-h3">NMR LipoProfile</h3>
            <p class="clarity-marker-card__tagline">We don't just measure your cholesterol. We count the particles.</p>
            <p class="clarity-body">Two people with identical LDL cholesterol can have completely different heart disease risk depending on particle size and number. NMR also gives us LP-IR score (insulin resistance at the lipoprotein level) and GlycA, a next-generation inflammation marker more stable than CRP.</p>
            <p class="clarity-marker-card__note">Standard panels measure the amount of cholesterol carried. NMR measures the number of vehicles carrying it.</p>
          </div>

          <div class="clarity-marker-card">
            <span class="clarity-marker-card__badge clarity-marker-card__badge--cardio">Cardiovascular</span>
            <h3 class="clarity-h3">ApoB</h3>
            <p class="clarity-marker-card__tagline">One number that supersedes traditional cholesterol.</p>
            <p class="clarity-body">Counts every atherogenic particle in your blood. The National Lipid Association (2024) and ACC/AHA (2022) both identify ApoB as the preferred cardiovascular target over LDL-C. This is the number we treat to.</p>
            <p class="clarity-marker-card__note">Your LDL-C can look fine while your ApoB is elevated. We track both, but we act on ApoB.</p>
          </div>

          <div class="clarity-marker-card">
            <span class="clarity-marker-card__badge clarity-marker-card__badge--metabolic">Metabolic</span>
            <h3 class="clarity-h3">Fasting Insulin</h3>
            <p class="clarity-marker-card__tagline">The number your previous doctor never checked.</p>
            <p class="clarity-body">Insulin resistance develops silently for years before HbA1c moves. Fasting insulin is the earliest detectable signal — it can flag a metabolic problem a decade before standard diabetes screening would catch it.</p>
            <p class="clarity-marker-card__note">The single biggest early-detection delta between Clarity and a standard primary care panel.</p>
          </div>

          <div class="clarity-marker-card">
            <span class="clarity-marker-card__badge clarity-marker-card__badge--performance">Performance</span>
            <h3 class="clarity-h3">Omega-3 Index</h3>
            <p class="clarity-marker-card__tagline">The fatty acid composition of your red blood cell membranes.</p>
            <p class="clarity-body">A target above 8% is cardiovascularly protective. Below 4% carries the same cardiac risk as smoking. Most people land between 4 and 6%. Responds to diet or supplementation within 120 days — which is why we test it at Month 6, not Month 3.</p>
            <p class="clarity-marker-card__note">Your omega-3 index reflects actual membrane incorporation — not what you ate last week.</p>
          </div>

          <div class="clarity-marker-card">
            <span class="clarity-marker-card__badge clarity-marker-card__badge--kidney">Kidney function</span>
            <h3 class="clarity-h3">Cystatin C with eGFR</h3>
            <p class="clarity-marker-card__tagline">We measure kidney function two ways.</p>
            <p class="clarity-body">Standard creatinine-based eGFR systematically misleads in lean, muscular patients and endurance athletes. Cystatin C gives an independent confirmation that doesn't depend on muscle mass.</p>
            <p class="clarity-marker-card__note">For active, health-optimizing patients, this matters more than most physicians realize.</p>
          </div>

          <div class="clarity-marker-card">
            <span class="clarity-marker-card__badge clarity-marker-card__badge--optin">Opt-in · With counseling</span>
            <h3 class="clarity-h3">APOE Genotype</h3>
            <p class="clarity-marker-card__tagline">How your brain ages, and how you respond to dietary fat.</p>
            <p class="clarity-body">Your APOE variant affects how you metabolize dietary fat, how we think about cardiovascular management, and how we approach dementia prevention. APOE ε4 carriers require meaningfully different strategies.</p>
            <p class="clarity-marker-card__note">GINA protects employment and health insurance. It does NOT protect life, long-term care, or disability insurance. We discuss this before testing.</p>
          </div>

          <div class="clarity-marker-card">
            <span class="clarity-marker-card__badge clarity-marker-card__badge--inflammation">Inflammation</span>
            <h3 class="clarity-h3">GlycA</h3>
            <p class="clarity-marker-card__tagline">A more stable inflammation signal than CRP.</p>
            <p class="clarity-body">Measured as part of the NMR LipoProfile, GlycA reflects a longer-term inflammation signal less susceptible to acute spikes from recent illness or intense training that can temporarily distort hs-CRP.</p>
            <p class="clarity-marker-card__note">Provides a cleaner trend line across the year.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- SECTION 8 — OUTCOMES -->
    <section class="clarity-outcomes">
      <div class="clarity-container">
        <p class="clarity-eyebrow">What the operating system delivers</p>
        <h2 class="clarity-h2">Not just data. A continuously updated picture of your health.</h2>
        <div class="clarity-outcomes__grid">

          <div class="clarity-outcome-item">
            <div class="clarity-outcome-item__bar"></div>
            <h3 class="clarity-h3">Your true cardiovascular risk — not a surrogate</h3>
            <p class="clarity-body">Coronary calcium, NMR particle counts, ApoB, and Lp(a) together give a far more accurate cardiovascular picture than any standard lipid panel. You'll know your actual risk and have a clear protocol for managing it.</p>
          </div>

          <div class="clarity-outcome-item">
            <div class="clarity-outcome-item__bar"></div>
            <h3 class="clarity-h3">A full-body structural baseline before symptoms arise</h3>
            <p class="clarity-body">The Prenuvo MRI creates a longitudinal record of your internal anatomy. If something changes, you have a reference point. Most of what's found in first-time scans would otherwise remain undetected until symptomatic.</p>
          </div>

          <div class="clarity-outcome-item">
            <div class="clarity-outcome-item__bar"></div>
            <h3 class="clarity-h3">Objective fitness benchmarks that compound over years</h3>
            <p class="clarity-body">VO₂ max and DEXA body composition measured consistently tell you whether your training, nutrition, and recovery are actually working — and in which direction you're trending over time.</p>
          </div>

          <div class="clarity-outcome-item">
            <div class="clarity-outcome-item__bar"></div>
            <h3 class="clarity-h3">A hormonal picture aligned with how you perform</h3>
            <p class="clarity-body">Not just whether you're 'in range' — but whether your full hormonal environment is optimized for energy, body composition, sleep quality, cognitive performance, and libido.</p>
          </div>

          <div class="clarity-outcome-item">
            <div class="clarity-outcome-item__bar"></div>
            <h3 class="clarity-h3">Real-time metabolic insight — and what's driving it</h3>
            <p class="clarity-body">Six weeks of continuous glucose data across three periods, read alongside fasting insulin and metabolic bloodwork, paired with a gut microbiome panel. The combination surfaces dysfunction years before standard screening flags anything.</p>
          </div>

          <div class="clarity-outcome-item">
            <div class="clarity-outcome-item__bar"></div>
            <h3 class="clarity-h3">A physician who operates the whole system</h3>
            <p class="clarity-body">The value of the Clarity Program is not any individual test — it is a physician who reads your MRI, labs, CGM patterns, DEXA, and VO₂ together, across time, and tells you what it means for you specifically.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- SECTION 9 — LIFESTYLE FIRST -->
    <section class="clarity-lifestyle">
      <div class="clarity-container">
        <div class="clarity-lifestyle__intro-grid">
          <div class="clarity-lifestyle__left">
            <p class="clarity-eyebrow">Our clinical philosophy</p>
            <h2 class="clarity-h2">Lifestyle changes first. Medication when genuinely necessary. Less over time, not more.</h2>
          </div>
          <div class="clarity-lifestyle__right">
            <p class="clarity-body">Most medical systems are optimized for prescribing. Clarity is optimized for not needing to. When your labs surface something worth acting on, the first question we ask is what lifestyle change — in nutrition, movement, sleep, or stress — could move this number before we consider a prescription.</p>
            <p class="clarity-body">This is where Dr. Lieberman's board certification in Lifestyle Medicine and culinary background become clinically meaningful. Behavioral interventions are not a consolation prize — they are the primary tool, with evidence that rivals or exceeds pharmacological options for many of the conditions we're tracking.</p>
            <p class="clarity-body">When medication is the right answer — and sometimes it clearly is — we use it at the lowest effective dose, monitor it at every draw, and revisit whether it's still necessary as your health improves. Deprescribing is as deliberate a clinical act as prescribing.</p>
          </div>
        </div>
        <div class="clarity-lifestyle__cards">
          <div class="clarity-lifestyle-card">
            <div class="clarity-lifestyle-card__bar"></div>
            <h3 class="clarity-h3">Lifestyle as first-line medicine</h3>
            <p class="clarity-body">Nutrition, exercise prescription, sleep optimization, and stress physiology aren't adjuncts — they're the intervention. We build them into your plan with the same specificity we apply to lab targets.</p>
          </div>
          <div class="clarity-lifestyle-card">
            <div class="clarity-lifestyle-card__bar"></div>
            <h3 class="clarity-h3">Medication when the evidence is clear</h3>
            <p class="clarity-body">Some conditions respond best or most safely to pharmacological treatment. We don't avoid medication ideologically. We use it judiciously, explain the reasoning, and monitor it at every draw.</p>
          </div>
          <div class="clarity-lifestyle-card">
            <div class="clarity-lifestyle-card__bar"></div>
            <h3 class="clarity-h3">Active deprescribing as health improves</h3>
            <p class="clarity-body">If you start the program on medications that were prescribed reactively, we actively evaluate whether they're still necessary as your biomarkers improve. Reducing a medication when it's no longer needed is a clinical goal, not an afterthought.</p>
          </div>
        </div>
      </div>
    </section>

