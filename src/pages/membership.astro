---
import MainLayout from '../layouts/MainLayout.astro';
import FAQSection from '../components/shared/FAQSection.astro';
import CTABanner from '../components/shared/CTABanner.astro';
import BotanicalGraphic from '../components/shared/BotanicalGraphic.astro';

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.forwardfamilymedicine.com" },
    { "@type": "ListItem", "position": 2, "name": "Membership", "item": "https://www.forwardfamilymedicine.com/membership" }
  ]
};

const faqs = [
  {
    q: 'Is this health insurance?',
    a: "No. DPC membership is not insurance. It covers your primary care needs directly. We recommend pairing it with a high-deductible health plan or health sharing plan to cover hospitalizations, surgeries, and specialist care.",
  },
  {
    q: 'Can I use my HSA or FSA for DPC membership?',
    a: "In many cases, yes — particularly following the Primary Care Enhancement Act (effective January 1, 2026), which clarified that HSA funds may be used for DPC memberships. Please confirm eligibility with your plan administrator.",
  },
  {
    q: 'What does my membership cover?',
    a: "Unlimited office visits (no copay), same-day and next-day appointments, visits of 1–2 hours, direct phone/text/email access to your doctor, preventive care, chronic disease management, minor procedures, wholesale lab pricing, telehealth, specialist referral coordination, and integrated Lifestyle Medicine with Dr. Lieberman.",
  },
  {
    q: "Are there any additional fees for Lifestyle Medicine?",
    a: "No. Lifestyle medicine is integrated into how Dr. Lieberman practices — it's part of your membership, not an add-on service.",
  },
  {
    q: 'Can I cancel my membership?',
    a: "All memberships include a 6-month minimum commitment from your enrollment date. After that period, month-to-month plans require 30 days' written notice to cancel.",
  },
  {
    q: "What if I need a specialist or hospital care?",
    a: "Your DPC membership covers primary care. For specialist referrals, we coordinate directly — calling ahead, advocating for you, and ensuring continuity of care. For hospitalizations and surgical care, you'll need a separate insurance plan.",
  },
];

const INDIVIDUAL_ENROLLMENT_LINK = 'https://forwardfamilymedicine.sigmamd.com/signup/individual-membership';
const FAMILY_ENROLLMENT_LINK = 'https://forwardfamilymedicine.sigmamd.com/signup/family-membership';
const PATIENT_PORTAL_LINK = 'https://patient.sigmamd.com';
---

<MainLayout
  title="Membership & Pricing | Forward Family Medicine Wayne PA"
  description="DPC membership plans at Forward Family Medicine in Wayne, PA. Individual and family options. Flat monthly fee. No insurance. Includes board-eligible Lifestyle Medicine."
  schema={breadcrumb}
>
  <!-- Hero -->
  <section class="membership-hero section" style="background: linear-gradient(160deg, var(--cream-100) 0%, var(--cream-300) 100%); position: relative; overflow: hidden;">
    <BotanicalGraphic variant="quartet" class="membership-botanical" />
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a> <span aria-hidden="true">›</span> <span>Membership</span>
      </nav>
      <span class="section-label">Simple, Transparent, Valuable</span>
      <h1>Membership &amp; Pricing</h1>
      <div class="divider"></div>
      <p class="section-intro">
        Concierge-quality care. DPC pricing. Lifestyle Medicine included. One flat monthly fee — no insurance, no copays, no surprises.
      </p>
      <div class="callout" style="margin-top:1.25rem; max-width:640px;">
        <strong>Physician availability:</strong> Dr. Lieberman is actively accepting new patients. Dr. Bigley is not currently accepting new patients.
      </div>
    </div>
  </section>

  <!-- Value Frame — Critical -->
  <section class="value-frame section" style="background: var(--green-500);">
    <div class="container value-frame-inner">
      <div class="value-quote">
        <span class="value-quote-mark" aria-hidden="true">"</span>
        <blockquote>
          Your membership includes something no other DPC practice on the Main Line
          offers: integrated, in-person Lifestyle Medicine. A physician
          with a culinary arts degree, a nutrition science background, and a Lifestyle
          Medicine certification who knows your name, answers your calls, and has
          a plan for your long-term health. That's what the membership covers.
        </blockquote>
      </div>
    </div>
  </section>

  <!-- Plans -->
  <section class="plans-section section">
    <div class="container">
      <span class="section-label">Choose Your Plan</span>
      <h2>Membership Options</h2>
      <div class="divider"></div>

      <div class="plans-grid">
        <!-- Individual -->
        <div class="plan-card card featured-plan">
          <div class="plan-header">
            <span class="plan-badge plan-badge-featured">Most Popular</span>
            <h3>Individual Membership</h3>
            <div class="plan-price">$200<span class="plan-price-unit">/month</span></div>
            <p class="plan-tagline">Primary care plus board-eligible lifestyle medicine — for you, personally.</p>
          </div>
          <ul class="prose-list plan-features">
            <li>Unlimited office visits, no copay</li>
            <li>Same-day and next-day appointments</li>
            <li>Visits: 1–2 hours</li>
            <li>Direct phone, text &amp; email access to your doctor</li>
            <li>Preventive care and annual wellness exams</li>
            <li>Chronic disease management</li>
            <li>Minor in-office procedures</li>
            <li>Wholesale lab and medication pricing</li>
            <li>Telehealth visits</li>
            <li>Specialist referral coordination</li>
            <li>Board-eligible Lifestyle Medicine (with Dr. Lieberman, dual board-eligible in Family Medicine &amp; Lifestyle Medicine)</li>
          </ul>
          <div class="plan-cta">
            <a href={INDIVIDUAL_ENROLLMENT_LINK} class="btn btn-primary plan-btn">Enroll as Individual</a>
            <a href="/contact" class="plan-greet-link">Or start with a free meet &amp; greet →</a>
            <div class="panel-notice">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              Panel size is capped at ~250 patients per physician. Spots fill — we recommend reaching out early.
            </div>
          </div>
        </div>

        <!-- Family -->
        <div class="plan-card card">
          <div class="plan-header">
            <span class="plan-badge plan-badge-accent">Family</span>
            <h3>Family Membership</h3>
            <div class="plan-price-family">
              <div class="family-tier"><span class="family-size">2 members</span><span class="family-rate">$175/person/month</span></div>
              <div class="family-tier"><span class="family-size">3 members</span><span class="family-rate">$150/person/month</span></div>
              <div class="family-tier"><span class="family-size">4 members</span><span class="family-rate">$125/person/month</span></div>
              <div class="family-tier"><span class="family-size">5+ members</span><span class="family-rate">$100/person/month</span></div>
            </div>
            <p class="plan-tagline">Whole-family care — every member gets direct access, real time, and genuine relationship.</p>
          </div>
          <ul class="prose-list plan-features">
            <li>Everything in Individual Membership</li>
            <li>Coverage for 2 or more family members</li>
            <li>Each member gets their own doctor relationship</li>
            <li>Coordinated family health planning</li>
            <li>Pediatric-friendly care options</li>
            <li>Wholesale lab pricing for the whole family</li>
            <li>All members access Lifestyle Medicine with Dr. Lieberman</li>
          </ul>
          <div class="plan-cta">
            <a href={FAMILY_ENROLLMENT_LINK} class="btn btn-accent plan-btn">Enroll Your Family</a>
            <a href="/contact" class="plan-greet-link">Or start with a free meet &amp; greet →</a>
          </div>
        </div>

        <!-- Business -->
        <div class="plan-card card">
          <div class="plan-header">
            <span class="plan-badge">Employer</span>
            <h3>Employer / Business</h3>
            <div class="plan-price employer-price">Custom Plan</div>
            <p class="employer-price-note">Priced per employee per month — built around your team size and structure.</p>
            <p class="plan-tagline">Better healthcare for your team — simpler than traditional insurance and genuinely more valuable.</p>
          </div>
          <ul class="prose-list plan-features">
            <li>Flat per-employee monthly membership</li>
            <li>Pairs with your existing health plan</li>
            <li>Employees get unlimited primary care, no copays</li>
            <li>Direct doctor access for your whole team</li>
            <li>Fewer sick days and ER visits</li>
            <li>Access to board-eligible Lifestyle Medicine</li>
            <li>Inquiry-based — we'll build a plan for your company</li>
          </ul>
          <div class="plan-cta">
            <a href="/for-businesses" class="btn btn-primary plan-btn">Learn About Employer Plans</a>
            <a href="/contact" class="plan-greet-link">Or contact us directly →</a>
          </div>
        </div>
      </div>

      <div class="pricing-note callout" style="max-width: 680px; margin: 2.5rem auto 1rem;">
        <strong>Children &amp; pediatric patients:</strong> Children are welcome at all ages. Children under 26 may be added to a family membership at the applicable per-person family rate. Contact us with questions about pediatric pricing.
      </div>

      <div class="pricing-note callout" style="max-width: 680px; margin: 0 auto 1rem; text-align:center;">
        Already a patient? <a href={PATIENT_PORTAL_LINK} target="_blank" rel="noopener noreferrer" style="color:var(--green-300); font-weight:600;">Log in to the Patient Portal →</a>
      </div>

      <div class="pricing-note callout" style="max-width: 680px; margin: 0 auto 1rem;">
        <strong>Panel size is capped at ~250 patients per physician</strong> to ensure timely access to your doctor. When a panel fills, we open a waitlist.
      </div>

      <div class="pricing-note callout" style="max-width: 680px; margin: 0 auto 0;">
        <strong>Not sure which plan is right for you?</strong>
        <p style="margin-top:0.4rem; margin-bottom:0;">
          Start with a free, no-obligation meet and greet. Come in, meet the team, ask
          every question — and we'll help you figure out the best fit. No pressure, no commitment.
        </p>
      </div>
    </div>
  </section>

  <!-- What's included deep dive -->
  <section class="included-section section" style="background: var(--cream-200);">
    <div class="container">
      <span class="section-label">Full Breakdown</span>
      <h2>What Your Membership Covers</h2>
      <div class="divider"></div>
      <div class="included-grid">
        <div class="included-category">
          <div class="included-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 12h6"/><path d="M9 16h4"/></svg>
          </div>
          <h3>Primary Care</h3>
          <ul class="prose-list">
            <li>Annual physicals and wellness exams</li>
            <li>Sick visits and acute care</li>
            <li>Preventive screenings</li>
            <li>Chronic condition monitoring</li>
            <li>Prescription management</li>
            <li>Lab review and follow-up</li>
          </ul>
        </div>
        <div class="included-category">
          <div class="included-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3>Access &amp; Convenience</h3>
          <ul class="prose-list">
            <li>Same-day and next-day appointments</li>
            <li>Visits: 1–2 hours</li>
            <li>Direct phone, text, and email access</li>
            <li>Telehealth included</li>
            <li>After-hours communication (urgent questions)</li>
          </ul>
        </div>
        <div class="included-category">
          <div class="included-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
          </div>
          <h3>Lifestyle Medicine</h3>
          <ul class="prose-list">
            <li>Comprehensive lifestyle assessment</li>
            <li>Personalized nutrition guidance</li>
            <li>Physical activity planning</li>
            <li>Sleep optimization</li>
            <li>Stress management</li>
            <li>Chronic disease reversal protocols</li>
          </ul>
        </div>
        <div class="included-category">
          <div class="included-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
          </div>
          <h3>Cost Savings</h3>
          <ul class="prose-list">
            <li>Wholesale lab pricing — CBC: $2 | CMP: $2 | Lipid panel: $3 | ApoB: $7 | Thyroid panel: $7</li>
            <li>Medications dispensed at cost — no pharmacy markup</li>
            <li>Reduced urgent care and ER visits through same-day access</li>
            <li>Discounted imaging coordination at local centers</li>
            <li>No per-visit fees, ever</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Clarity Tier -->
  <section class="clarity-tier-section">
    <div class="container">
      <div class="clarity-tier-card">
        <div class="clarity-tier-left">
          <span class="clarity-tier-badge">Executive Health Program</span>
          <h2 class="clarity-tier-h2">The Clarity Program</h2>
          <p class="clarity-tier-desc">A physician-led longitudinal health operating system — Prenuvo whole-body MRI, advanced biomarker panels, gut microbiome, continuous glucose monitoring, DEXA, and VO₂ max, read together by a single physician across your full program year.</p>
          <div class="clarity-tier-chips">
            <span class="clarity-tier-chip">Prenuvo whole-body MRI</span>
            <span class="clarity-tier-chip">~250 biomarker results/year</span>
            <span class="clarity-tier-chip">Gut microbiome panel</span>
            <span class="clarity-tier-chip">6 weeks CGM</span>
            <span class="clarity-tier-chip">DEXA 2×/year</span>
            <span class="clarity-tier-chip">VO₂ max 2×/year</span>
            <span class="clarity-tier-chip">Full FFM membership included</span>
          </div>
        </div>
        <div class="clarity-tier-right">
          <p class="clarity-tier-price">$9,600</p>
          <p class="clarity-tier-period">per year · paid annually · HSA-eligible</p>
          <div class="clarity-tier-ctas">
            <a href="/clarity/" class="clarity-tier-btn-primary">See the full program</a>
            <a href="/new-patients/?source=clarity" class="clarity-tier-btn-ghost">Schedule an inquiry call →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FAQSection faqs={faqs} headline="Membership FAQs" />
  <CTABanner
    headline="The Best Time to Start Is Now"
    subhead="Begin with a free, no-obligation meet and greet. No paperwork, no credit card, no pressure. Just a conversation with your future doctor."
    btn2Text="Enroll Now →"
    btn2Href={INDIVIDUAL_ENROLLMENT_LINK}
  />
</MainLayout>

<style>
  .membership-botanical {
    position: absolute;
    right: -60px;
    top: 50%;
    transform: translateY(-50%);
    width: 380px;
    height: 380px;
    opacity: 0.2;
    pointer-events: none;
  }
  @media (max-width: 860px) {
    .membership-botanical { display: none; }
  }
  .breadcrumb {
    font-size: 0.85rem;
    color: var(--ink-300);
    margin-bottom: 1.5rem;
  }
  .breadcrumb a { color: var(--green-300); text-decoration: none; }

  /* Value Frame */
  .value-frame-inner {
    max-width: 800px;
    margin: 0 auto;
  }
  .value-quote {
    position: relative;
    padding-left: 2rem;
  }
  .value-quote-mark {
    position: absolute;
    left: -0.5rem;
    top: -1rem;
    font-family: var(--font-heading);
    font-size: 6rem;
    color: rgba(255,255,255,0.15);
    line-height: 1;
    pointer-events: none;
  }
  .value-quote blockquote {
    font-family: var(--font-heading);
    font-size: clamp(1.1rem, 2.5vw, 1.35rem);
    color: white;
    line-height: 1.7;
    font-style: italic;
    margin: 0;
  }

  /* Plans */
  .plans-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.75rem;
    margin-top: 2rem;
  }
  .plan-card {
    display: flex;
    flex-direction: column;
  }
  .featured-plan {
    border: 2px solid var(--green-400);
    position: relative;
  }
  .plan-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: var(--green-100);
    color: var(--ink-900);
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    margin-bottom: 0.75rem;
  }
  .plan-badge-accent {
    background: #fdf0e6;
    color: #b86a30;
  }
  .plan-badge-featured {
    background: var(--green-500);
    color: white;
  }
  .plan-header h3 {
    margin-bottom: 0.5rem;
  }
  .plan-price {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--ink-900);
    font-family: var(--font-heading);
    margin: 0.5rem 0 0.75rem;
    line-height: 1;
  }
  .plan-price-unit {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--ink-300);
  }
  .plan-price-family {
    margin: 0.5rem 0 0.75rem;
  }
  .family-tier {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.3rem 0;
    border-bottom: 1px solid var(--ink-100);
    font-size: 0.9rem;
  }
  .family-tier:last-child { border-bottom: none; }
  .family-size { color: var(--ink-700); }
  .family-rate { font-weight: 700; color: var(--ink-900); }

  .plan-tagline {
    font-size: 0.9rem;
    color: var(--ink-500);
    margin-bottom: 1.5rem;
    line-height: 1.55;
  }
  .plan-features {
    flex: 1;
    margin-bottom: 2rem;
  }
  .plan-cta {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: auto;
  }
  .plan-btn {
    width: 100%;
    text-align: center;
  }
  .plan-greet-link {
    font-size: 0.85rem;
    color: var(--green-300);
    text-decoration: none;
    text-align: center;
    transition: color 0.15s;
  }
  .plan-greet-link:hover { color: var(--green-400); }
  .panel-notice {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--ink-500);
    background: var(--cream-200);
    border: 1px solid var(--cream-300);
    border-radius: 999px;
    padding: 0.4rem 0.9rem;
    margin-top: 1rem;
  }
  .panel-notice svg {
    color: var(--green-400);
    flex-shrink: 0;
  }

  .employer-price {
    font-size: 1.4rem;
    color: var(--ink-700);
  }
  .employer-price-note {
    font-size: 0.82rem;
    color: var(--ink-400);
    margin-top: -0.25rem;
    margin-bottom: 0.75rem;
    line-height: 1.5;
  }

  /* Included grid */
  .included-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    margin-top: 2rem;
  }
  .included-category {
    background: white;
    border-radius: var(--radius);
    padding: 1.5rem;
    box-shadow: var(--shadow-sm);
  }
  .included-icon {
    color: var(--green-400);
    margin-bottom: 0.6rem;
  }
  .included-category h3 {
    font-size: 1.05rem;
    margin-bottom: 0.75rem;
  }

  /* Clarity Tier */
  .clarity-tier-section {
    background: var(--cream-50);
    padding: 2.5rem 0;
  }
  .clarity-tier-card {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2.5rem;
    align-items: center;
    background: var(--ink-900);
    border-radius: var(--radius);
    padding: 2.25rem 2.5rem;
  }
  .clarity-tier-badge {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--green-400);
    border: 1px solid rgba(90, 136, 96, 0.35);
    border-radius: 4px;
    padding: 0.25rem 0.6rem;
    margin-bottom: 0.9rem;
  }
  .clarity-tier-h2 {
    font-family: var(--font-heading);
    font-size: clamp(1.6rem, 3vw, 2.1rem);
    font-weight: 300;
    color: #fff;
    margin: 0 0 0.85rem;
    line-height: 1.2;
  }
  .clarity-tier-desc {
    font-size: 0.93rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.5);
    font-weight: 300;
    margin: 0 0 1.25rem;
    max-width: 560px;
  }
  .clarity-tier-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .clarity-tier-chip {
    font-size: 0.72rem;
    font-weight: 500;
    color: rgba(255,255,255,0.65);
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 4px;
    padding: 0.2rem 0.55rem;
    white-space: nowrap;
  }
  .clarity-tier-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
    min-width: 220px;
  }
  .clarity-tier-price {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 400;
    color: #fff;
    margin: 0;
    line-height: 1;
  }
  .clarity-tier-period {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.45);
    margin: 0 0 1.25rem;
    text-align: right;
  }
  .clarity-tier-ctas {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.6rem;
    width: 100%;
  }
  .clarity-tier-btn-primary {
    display: block;
    text-align: center;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    background: var(--green-500);
    color: #fff;
    border: 2px solid var(--green-500);
    border-radius: var(--radius-sm);
    padding: 0.65rem 1.25rem;
