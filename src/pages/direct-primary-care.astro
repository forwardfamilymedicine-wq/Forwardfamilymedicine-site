---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="What Is Direct Primary Care? | Forward Family Medicine Wayne, PA"
  description="Direct Primary Care (DPC) is a membership-based primary care model where you pay a flat monthly fee directly to your doctor — no insurance billing, no copays, no rushed visits."
  canonical="https://www.forwardfamilymedicine.com/direct-primary-care"
>

  <!-- ─── Hero ──────────────────────────────────────────────────── -->
  <section class="page-hero">
    <div class="container">
      <p class="hero-eyebrow">Wayne, PA · Philadelphia Main Line</p>
      <h1>What Is Direct Primary Care?</h1>
      <p class="hero-desc">Primary care freed from insurance billing — and built around you. At Forward Family Medicine, DPC isn't a budget alternative to concierge medicine. It's the financial structure that makes concierge-quality care available to everyone.</p>
    </div>
  </section>

  <!-- ─── Stats ─────────────────────────────────────────────────── -->
  <section class="section stats-section">
    <div class="container">
      <div class="stat-row">
        <div class="stat-card">
          <strong class="stat-number">≤250</strong>
          <span class="stat-label">patients per physician — capped</span>
        </div>
        <div class="stat-card">
          <strong class="stat-number">1–2 hr</strong>
          <span class="stat-label">typical visit length</span>
        </div>
        <div class="stat-card">
          <strong class="stat-number">$200<span class="stat-unit">/mo</span></strong>
          <span class="stat-label">individual membership</span>
        </div>
        <div class="stat-card">
          <strong class="stat-number">$0</strong>
          <span class="stat-label">copays, ever</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── What DPC Covers ───────────────────────────────────────── -->
  <section class="section section-alt">
    <div class="container">
      <span class="section-label">Membership Benefits</span>
      <h2 class="section-title">What DPC Covers at Forward Family Medicine</h2>
      <div class="coverage-grid">
        <div class="coverage-col">
          <p class="coverage-heading included">✓ Included in Membership</p>
          <ul class="prose-list">
            <li>Unlimited office visits (in-person, phone, video)</li>
            <li>Same-day or next-day scheduling</li>
            <li>Direct physician access — call, text, message</li>
            <li>Annual physicals and preventive screenings</li>
            <li>Acute illness care (infections, injuries, etc.)</li>
            <li>Chronic disease management</li>
            <li>Prescription refills and medication management</li>
            <li>Lifestyle medicine and health coaching</li>
            <li>Minor in-office procedures</li>
          </ul>
        </div>
        <div class="coverage-col">
          <p class="coverage-heading addon">+ At-Cost Add-Ons</p>
          <ul class="prose-list">
            <li>Lab work at wholesale/near-cost pricing</li>
            <li>Medications dispensed at cost — no pharmacy markup</li>
            <li>Immunizations at cost</li>
          </ul>
          <p class="coverage-heading notcovered" style="margin-top:2rem;">✕ Not Covered by DPC</p>
          <ul class="prose-list" style="--check-color: var(--ink-300);">
            <li>Specialist visits (billed through your insurance)</li>
            <li>Hospital care and emergency services</li>
            <li>Imaging — we help coordinate and advocate for you</li>
          </ul>
          <p style="font-size:0.85rem; color:var(--ink-500); margin-top:1.25rem;"><a href="/services">See the full services list →</a></p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Lab Pricing ───────────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <span class="section-label">Transparent Pricing</span>
      <h2 class="section-title">Wholesale Lab Pricing — What You Actually Pay</h2>
      <p class="section-intro" style="margin-bottom:2.5rem;">These are the prices you pay. Not an insurance "negotiated" rate. Not a facility fee. Just the lab cost — passed directly to you.</p>
      <div class="lab-grid">
        <div class="lab-item">
          <strong class="lab-price">$2</strong>
          <span class="lab-name">CBC</span>
          <span class="lab-full">Complete Blood Count</span>
        </div>
        <div class="lab-item">
          <strong class="lab-price">$2</strong>
          <span class="lab-name">CMP</span>
          <span class="lab-full">Comprehensive Metabolic Panel</span>
        </div>
        <div class="lab-item">
          <strong class="lab-price">$3</strong>
          <span class="lab-name">Lipid Panel</span>
          <span class="lab-full">Total cholesterol, LDL, HDL, triglycerides</span>
        </div>
        <div class="lab-item">
          <strong class="lab-price">$7</strong>
          <span class="lab-name">ApoB</span>
          <span class="lab-full">Advanced cardiovascular risk marker</span>
        </div>
        <div class="lab-item">
          <strong class="lab-price">$7</strong>
          <span class="lab-name">Thyroid Panel</span>
          <span class="lab-full">TSH + additional thyroid markers</span>
        </div>
        <div class="lab-item lab-item-more">
          <strong class="lab-price-more">+ more</strong>
          <span class="lab-full">Full menu available at your visit</span>
        </div>
      </div>
      <p class="lab-footnote">Medications are also dispensed at cost through direct supplier relationships. No pharmacy markup.</p>
    </div>
  </section>

  <!-- ─── DPC vs Traditional Comparison Table ───────────────────── -->
  <section class="section section-alt">
    <div class="container">
      <span class="section-label">The Comparison</span>
      <h2 class="section-title">How DPC Is Different from Traditional Primary Care</h2>
      <div class="table-wrap">
        <table class="compare-table">
          <thead>
            <tr>
              <th>Feature</th>
              <th class="col-trad">Traditional Primary Care</th>
              <th class="col-ffm">Forward Family Medicine (DPC)</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="row-feature">Payment</td>
              <td class="col-trad">Insurance + copays + deductibles</td>
              <td class="col-ffm">Flat monthly membership fee</td>
            </tr>
            <tr>
              <td class="row-feature">Visit length</td>
              <td class="col-trad">7–12 minutes (typical)</td>
              <td class="col-ffm">1–2 hours</td>
            </tr>
            <tr>
              <td class="row-feature">Doctor access</td>
              <td class="col-trad">Via scheduling + nurse line</td>
              <td class="col-ffm">Direct — call, text, message</td>
            </tr>
            <tr>
              <td class="row-feature">Wait for appointment</td>
              <td class="col-trad">Days to weeks</td>
              <td class="col-ffm">Same or next day</td>
            </tr>
            <tr>
              <td class="row-feature">Patient panel size</td>
              <td class="col-trad">2,000–3,000 patients</td>
              <td class="col-ffm">~250 patients per physician</td>
            </tr>
            <tr>
              <td class="row-feature">After-hours access</td>
              <td class="col-trad">Answering service / urgent care</td>
              <td class="col-ffm">Your own doctor (for true clinical urgency)</td>
            </tr>
            <tr>
              <td class="row-feature">Preventive focus</td>
              <td class="col-trad">Often squeezed out</td>
              <td class="col-ffm">Central to every visit</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ─── Cost Comparison ───────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <span class="section-label">Real Numbers</span>
      <h2 class="section-title">What Does DPC Actually Cost You?</h2>
      <p class="section-intro" style="margin-bottom:2.5rem;">Most DPC members pair their membership with a high-deductible health plan (HDHP) for specialist and hospital coverage. A rough comparison for a healthy adult:</p>
      <div class="cost-compare">
        <div class="cost-card cost-card-trad">
          <h3>Traditional PPO Only</h3>
          <p class="cost-amount">$400–600+<span>/mo</span></p>
          <ul>
            <li>7–12 minute visits</li>
            <li>Wait days to weeks</li>
            <li>Still paying copays on top</li>
            <li>2,000–3,000 patient panel</li>
          </ul>
        </div>
        <div class="cost-card cost-card-dpc">
          <span class="cost-badge">Better Value</span>
          <h3>FFM Membership + HDHP</h3>
          <p class="cost-amount">$300–400<span>/mo combined (est.)</span></p>
          <ul>
            <li>1–2 hour visits</li>
            <li>Same-day access</li>
            <li>No copays on primary care</li>
            <li>≤250 patient panel</li>
          </ul>
        </div>
      </div>
      <p class="cost-note">Estimates vary widely by age, employer, and plan. Many members find their total annual healthcare spend decreases significantly. Consult a benefits advisor for your specific situation.</p>
    </div>
  </section>

  <!-- ─── Inline CTA ────────────────────────────────────────────── -->
  <div class="section" style="background: var(--cream-100);">
    <div class="container">
      <div class="inline-cta">
        <h2>Want to See If DPC Is Right for You?</h2>
        <p>Start with a free, no-obligation meet and greet. Meet the physicians, ask every question, and decide with zero pressure.</p>
        <div class="inline-cta-btns">
          <a href="/contact" class="btn btn-accent">Schedule a Free Meet &amp; Greet</a>
          <a href="/membership" class="btn btn-outline-white">See Membership Plans →</a>
        </div>
      </div>
    </div>
  </div>

  <!-- ─── Is DPC Right for You ──────────────────────────────────── -->
  <section class="section section-alt">
    <div class="container">
      <span class="section-label">Who It's For</span>
      <h2 class="section-title">Is DPC Right for You?</h2>
      <div class="persona-grid">
        <div class="persona-card">
          <span class="persona-icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></span>
          <h3>Families &amp; Individuals</h3>
          <p>Without employer-sponsored insurance who want excellent primary care at a predictable monthly cost.</p>
        </div>
        <div class="persona-card">
          <span class="persona-icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></span>
          <h3>Chronic Condition Management</h3>
          <p>Diabetes, hypertension, thyroid disorders — conditions that need ongoing, attentive management — not a 10-minute slot every 3 months.</p>
        </div>
        <div class="persona-card">
          <span class="persona-icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></span>
          <h3>Prevention-Focused Patients</h3>
          <p>Who want real time with their doctor to work on root causes, lifestyle changes, and long-term health goals.</p>
        </div>
        <div class="persona-card">
          <span class="persona-icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg></span>
          <h3>Self-Employed &amp; Small Business</h3>
          <p>Looking for a cost-effective health benefit that delivers concierge-quality care without the concierge price tag.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── FAQ ───────────────────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <span class="section-label">Common Questions</span>
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">
            <span>What does "direct" mean in Direct Primary Care?</span>
            <span class="faq-toggle" aria-hidden="true">+</span>
          </button>
          <div class="faq-a" hidden>
            <p>"Direct" refers to the direct financial relationship between patient and physician — you pay your doctor directly, without an insurance company in the middle. This removes administrative overhead and aligns incentives around your health, not billing volume.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">
            <span>Is DPC covered by Medicare or Medicaid?</span>
            <span class="faq-toggle" aria-hidden="true">+</span>
          </button>
          <div class="faq-a" hidden>
            <p>DPC membership fees are not covered by Medicare or Medicaid. However, Medicare and Medicaid beneficiaries can join a DPC practice as cash-paying members. Specialty and hospital services would still be billed through Medicare or Medicaid as applicable.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">
            <span>How is DPC different from concierge medicine?</span>
            <span class="faq-toggle" aria-hidden="true">+</span>
          </button>
          <div class="faq-a" hidden>
            <p>The distinction most practices draw between DPC and concierge medicine doesn't apply at Forward Family Medicine. Every member receives what the industry calls a "concierge experience" — delivered through the DPC financial model: no insurance billing, predictable monthly pricing. <a href="/concierge-medicine">Learn more about our concierge features →</a> For members who want to layer comprehensive imaging, advanced biomarker testing, and longitudinal physician guidance on top of their DPC membership, the <a href="/clarity/">Clarity Program</a> is our integrated executive health offering.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">
            <span>Does the monthly fee really cover everything in primary care?</span>
            <span class="faq-toggle" aria-hidden="true">+</span>
          </button>
          <div class="faq-a" hidden>
            <p>It covers the vast majority of what most people need from a primary care physician. You only pay extra for labs, medications, and immunizations — and even then, at cost. No per-visit fees, ever.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">
            <span>How do I know if this practice is a good fit before joining?</span>
            <span class="faq-toggle" aria-hidden="true">+</span>
          </button>
          <div class="faq-a" hidden>
            <p>That's exactly what our free Meet &amp; Greet is for. <a href="/contact">Schedule one here →</a> It's a 20-minute conversation — in person or by video — with no pressure and no commitment.</p>
          </div>
        </div>
      </div>
      <p style="margin-top:2rem; font-size:0.9rem; color:var(--ink-500);">More questions? <a href="/faq">See our full FAQ →</a></p>
    </div>
  </section>

  <!-- ─── Bottom CTA ────────────────────────────────────────────── -->
  <section class="bottom-cta">
    <div class="container bottom-cta-inner">
      <div class="bottom-cta-text">
        <h2>Take the Next Step</h2>
        <p>See the practice, meet Dr. Bigley and Dr. Lieberman, and ask every DPC question you have — no obligation, no pressure.</p>
      </div>
      <div class="bottom-cta-btns">
        <a href="/contact" class="btn btn-accent">Schedule a Free Meet &amp; Greet</a>
        <a href="/membership" class="btn btn-outline-white">Explore Membership Plans →</a>
      </div>
    </div>
  </section>

</MainLayout>

<style>
  /* ─── Hero ─────────────────────────────────── */
  .page-hero {
    background: var(--green-500);
    padding: clamp(48px, 8vw, 80px) 0;
  }
  .hero-eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--green-200);
    margin-bottom: 0.75rem;
  }
  .page-hero h1 {
    color: #ffffff;
    margin-bottom: 0.75rem;
  }
  .hero-desc {
    color: var(--green-100);
    font-size: clamp(1rem, 2vw, 1.15rem);
    max-width: 700px;
    line-height: 1.7;
    margin: 0;
  }

  /* ─── Stats ─────────────────────────────────── */
  .stats-section { background: var(--cream-100); }
  .stat-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }
  .stat-card {
    background: var(--green-50);
    border: 1px solid var(--green-100);
    border-radius: 16px;
    padding: 1.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .stat-number {
    font-family: var(--font-heading);
    font-size: 2.25rem;
    color: var(--green-500);
    line-height: 1;
  }
  .stat-unit {
    font-size: 1.25rem;
  }
  .stat-label {
    font-size: 0.82rem;
    color: var(--ink-500);
    line-height: 1.4;
  }

  /* ─── Section alternates ──────────────────── */
  .section-alt { background: var(--cream-200); }

  /* ─── Coverage ──────────────────────────────── */
  .coverage-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    margin-top: 2rem;
  }
  .coverage-heading {
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1rem;
  }
  .coverage-heading.included { color: var(--green-500); }
  .coverage-heading.addon { color: var(--green-400); }
  .coverage-heading.notcovered { color: var(--ink-500); }

  /* ─── Lab pricing ──────────────────────────── */
  .lab-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .lab-item {
    background: var(--green-50);
    border: 1px solid var(--green-100);
    border-radius: 16px;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .lab-price {
    font-family: var(--font-heading);
    font-size: 2.25rem;
    color: var(--green-500);
    line-height: 1;
  }
  .lab-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--ink-900);
  }
  .lab-full {
    font-size: 0.8rem;
    color: var(--ink-500);
  }
  .lab-item-more {
    background: var(--warm-50);
    border-color: var(--warm-200);
    justify-content: center;
    align-items: center;
    text-align: center;
  }
  .lab-price-more {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    color: var(--ink-500);
  }
  .lab-footnote {
    margin-top: 1.5rem;
    font-size: 0.85rem;
    color: var(--ink-500);
  }

  /* ─── Comparison table ──────────────────────── */
  .table-wrap {
    overflow-x: auto;
    border-radius: 16px;
    border: 1px solid var(--cream-300);
    margin-top: 2rem;
    box-shadow: var(--shadow-sm);
  }
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.93rem;
    margin: 0;
  }
  .compare-table thead th {
    padding: 1rem 1.25rem;
    text-align: left;
    font-weight: 600;
    border: none;
    background: var(--green-500);
    color: #ffffff;
  }
  .compare-table thead th.col-trad {
    background: var(--warm-200);
    color: var(--ink-900);
  }
  .compare-table thead th.col-ffm {
    background: var(--green-300);
    color: #ffffff;
  }
  .compare-table tbody tr { border-bottom: 1px solid var(--cream-300); }
  .compare-table tbody tr:last-child { border-bottom: none; }
  .compare-table td {
    padding: 0.85rem 1.25rem;
    border: none;
    border-right: 1px solid var(--cream-300);
  }
  .compare-table td:last-child { border-right: none; }
  .compare-table tbody tr:nth-child(even) { background: var(--warm-100); }
  .compare-table tbody tr td.col-ffm { background: var(--green-50); }
  .row-feature { font-weight: 600; color: var(--ink-900); }
  .col-trad { color: var(--ink-500); }
  .col-ffm { color: var(--green-500); font-weight: 500; }

  /* ─── Cost comparison ──────────────────────── */
  .cost-compare {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    max-width: 680px;
  }
  .cost-card {
    border-radius: 16px;
    padding: 2rem;
    position: relative;
  }
  .cost-card-trad {
    background: var(--warm-50);
    border: 1px solid var(--warm-200);
  }
  .cost-card-dpc {
    background: var(--green-50);
    border: 2px solid var(--green-300);
  }
  .cost-card h3 {
    font-size: 1rem;
    margin-bottom: 0.75rem;
    color: var(--ink-900);
  }
  .cost-amount {
    font-family: var(--font-heading);
    font-size: 2rem;
    color: var(--ink-900);
    margin-bottom: 1.25rem;
    line-height: 1.1;
  }
  .cost-amount span {
    font-family: var(--font-body);
    font-size: 0.88rem;
    color: var(--ink-500);
  }
  .cost-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 0.88rem;
    color: var(--ink-700);
  }
  .cost-card li {
    padding: 0.3rem 0 0.3rem 1.4rem;
    position: relative;
  }
  .cost-card-dpc li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--green-400);
    font-weight: 700;
  }
  .cost-card-trad li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--ink-300);
  }
  .cost-badge {
    position: absolute;
    top: -0.75rem;
    right: 1.5rem;
    background: var(--green-400);
    color: #ffffff;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
  }
  .cost-note {
    font-size: 0.8rem;
    color: var(--ink-300);
    margin-top: 1.5rem;
  }

  /* ─── Inline CTA ───────────────────────────── */
  .inline-cta {
    background: var(--green-500);
    border-radius: 20px;
    padding: clamp(2rem, 5vw, 3rem) clamp(1.5rem, 5vw, 3rem);
    text-align: center;
  }
  .inline-cta h2 {
    color: #ffffff;
    margin-bottom: 0.75rem;
  }
  .inline-cta p {
    color: var(--green-100);
    font-size: 1.05rem;
    max-width: 560px;
    margin: 0 auto 1.75rem;
  }
  .inline-cta-btns {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ─── Personas ──────────────────────────────── */
  .persona-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin-top: 2rem;
  }
