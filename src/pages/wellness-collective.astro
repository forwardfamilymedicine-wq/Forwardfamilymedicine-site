    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    color: var(--green-400);
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    flex-shrink: 0;
  }
  .wc-step-circle:hover,
  .wc-step:hover .wc-step-circle {
    background: var(--green-500);
    border-color: var(--green-500);
    color: #ffffff;
  }
  .wc-step-num {
    position: absolute;
    top: -8px;
    right: -8px;
    width: 20px;
    height: 20px;
    background: rgba(184,135,58,0.9);
    color: #ffffff;
