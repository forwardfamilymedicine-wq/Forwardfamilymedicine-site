    margin: 0;
  }

  /* ─── Areas of Care ─────────────────────────────────────── */
  .wc-areas { background: var(--cream-50); }
  .wc-areas-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  .wc-area-card {
    background: #ffffff;
    border: 1px solid var(--cream-200);
    border-radius: var(--radius);
    padding: 1.75rem;
    position: relative;
    transition: transform 0.2s, box-shadow 0.2s, border-top-color 0.2s;
    border-top: 2px solid transparent;
    overflow: hidden;
  }
  .wc-area-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--green-500), var(--green-300));
    opacity: 0;
    transition: opacity 0.2s;
  }
  .wc-area-card:hover::before { opacity: 1; }
  .wc-area-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  .wc-area-card .wc-icon-box { margin-bottom: 0.85rem; }
  .wc-area-card h3 {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--ink-900);
