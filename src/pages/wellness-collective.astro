    font-family: var(--font-body);
    font-weight: 300;
    font-size: 0.8rem;
    color: var(--ink-700);
    padding: 0.2rem 0.65rem;
  }

  /* ─── How It Works ──────────────────────────────────────── */
  .wc-how { background: #ffffff; }
  .wc-steps {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 3.5rem;
  }
  .wc-connector {
    position: absolute;
    top: 35px;
    left: calc(16.666% + 34px);
    right: calc(16.666% + 34px);
    height: 1px;
    background: linear-gradient(90deg, var(--green-200), var(--green-400), var(--green-200));
    z-index: 0;
  }
  .wc-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    z-index: 1;
  }
  .wc-step-circle {
    position: relative;
    width: 68px;
    height: 68px;
    background: var(--cream-50);
    border: 2px solid var(--green-400);
    border-radius: 50%;
