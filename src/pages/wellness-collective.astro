---
import MainLayout from '../layouts/MainLayout.astro';
import FAQSection from '../components/shared/FAQSection.astro';
import CTABanner from '../components/shared/CTABanner.astro';
import BotanicalGraphic from '../components/shared/BotanicalGraphic.astro';

const faqs = [
  {
    q: "Is the Wellness Collective an extra cost?",
    a: "No. Access to the Collective is included in your standard FFM membership. There is no separate enrollment, no additional monthly fee, and no referral charge. The only costs are what individual Collective providers charge for their services — many of which offer preferred pricing for our members.",
  },
  {
    q: "How are providers chosen for the network?",
    a: "Every Collective partner is individually vetted by Dr. Bigley or Dr. Lieberman — not sourced from an insurance directory. We evaluate for clinical credentials, a one-on-one care model, and alignment with a proactive, prevention-focused philosophy. High-volume or impersonal practices are not included, regardless of their general reputation.",
  },
  {
    q: "Can I still see providers outside the Collective?",
    a: "Yes, absolutely. The Collective is a benefit, not a restriction. If you have a provider you already trust, your physician will coordinate with them directly. The Collective is most useful when you don't yet have an established relationship in a given category.",
  },
  {
    q: "Do Collective providers accept insurance?",
    a: "It varies by provider. Many of the highest-quality Collective partners — particularly in physical therapy, chiropractic, nutrition, and fitness — operate on a cash-pay or hybrid model. Your physician will always clarify payment structure before making a referral. Some providers offer superbills for out-of-network reimbursement.",
  },
  {
    q: "Will the network grow over time?",
    a: "Yes. The Collective is a living resource. As FFM grows, we continue to evaluate and add partners across new categories and geographies on the Main Line. If there's a category or area you'd like to see represented, let us know — member feedback directly shapes who we recruit next.",
  },
];
---

<MainLayout
  title="The Main Line Wellness Collective | Forward Family Medicine"
  description="A physician-curated network of best-in-class wellness and specialty providers on the Main Line — included in every Forward Family Medicine membership."
  canonical="https://www.forwardfamilymedicine.com/wellness-collective"
>

  <!-- ─── Breadcrumb ─────────────────────────────────────────── -->
  <nav class="wc-breadcrumb" aria-label="Breadcrumb">
    <div class="container">
      <a href="/">Home</a>
      <span aria-hidden="true"> › </span>
      <a href="/services">Services</a>
      <span aria-hidden="true"> › </span>
      <span>Wellness Collective</span>
    </div>
  </nav>

  <!-- ─── 1. HERO ───────────────────────────────────────────── -->
  <section class="wc-hero section wc-reveal">
    <div class="wc-hero-pattern" aria-hidden="true"></div>
    <div class="container wc-hero-inner">
      <div class="wc-hero-content">
        <span class="section-label">A Member Benefit of Forward Family Medicine</span>
        <h1>Care that extends <em>beyond our walls</em></h1>
        <p class="wc-hero-sub">The Main Line Wellness Collective is a physician-curated network of best-in-class wellness and specialty providers — personally vetted by your doctor and available exclusively to Forward Family Medicine members, at no extra cost.</p>
        <div class="wc-hero-ctas">
          <a href="/contact" class="btn btn-accent">Schedule a Free Meet &amp; Greet</a>
          <a href="#what-it-is" class="wc-ghost-link">Learn how it works</a>
        </div>
      </div>
      <BotanicalGraphic variant="bloom" class="wc-botanical" position="inline" />
    </div>
  </section>

  <!-- ─── 2. WHAT IT IS ─────────────────────────────────────── -->
  <section class="section wc-what wc-reveal" id="what-it-is">
    <div class="container wc-what-inner">
      <div class="wc-what-left">
        <span class="badge">The Collective</span>
        <h2 style="margin-top:1rem;">A referral network <em>built differently.</em></h2>
        <p class="wc-body-text">Most referrals work the same way: your doctor prints a name and a phone number, and you're on your own. The Wellness Collective is the opposite of that.</p>
        <p class="wc-body-text">Every provider in the network has been personally evaluated by Dr. Bigley or Dr. Lieberman — not sourced from an insurance directory or recommendation platform. We selected for clinical depth, a one-on-one care model, and a philosophy that aligns with how we practice: preventive, personalized, unhurried.</p>
        <p class="wc-body-text">When you need care beyond our office, we identify the right partner for your specific situation, make a direct introduction, and share your clinical context — so your new provider understands you before you walk in the door.</p>
      </div>
      <div class="wc-what-right">
        <div class="wc-diff-card">
          <p class="wc-diff-title">What makes this different</p>
          <ul class="wc-check-list">
            <li>
              <span class="wc-check-icon" aria-hidden="true"><svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="9" fill="var(--green-500)"/><polyline points="5,9 8,12 13,6" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              Every provider is independently vetted — not from a hospital network list
            </li>
            <li>
              <span class="wc-check-icon" aria-hidden="true"><svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="9" fill="var(--green-500)"/><polyline points="5,9 8,12 13,6" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              Most partners are small, independent, or cash-based practices — the same model as DPC
            </li>
            <li>
              <span class="wc-check-icon" aria-hidden="true"><svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="9" fill="var(--green-500)"/><polyline points="5,9 8,12 13,6" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              We make the introduction directly, with your clinical context included
            </li>
            <li>
              <span class="wc-check-icon" aria-hidden="true"><svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="9" fill="var(--green-500)"/><polyline points="5,9 8,12 13,6" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              Many partners offer priority scheduling and preferred rates for FFM members
            </li>
            <li>
              <span class="wc-check-icon" aria-hidden="true"><svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="9" fill="var(--green-500)"/><polyline points="5,9 8,12 13,6" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              Access is reserved for members — this is not a public directory
            </li>
            <li>
              <span class="wc-check-icon" aria-hidden="true"><svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="9" fill="var(--green-500)"/><polyline points="5,9 8,12 13,6" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              Your physician stays informed as your care progresses
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── 3. WHY IT MATTERS ─────────────────────────────────── -->
  <section class="section wc-why wc-reveal">
    <div class="container">
      <div class="wc-section-header wc-centered">
        <span class="section-label">Why It Matters</span>
        <h2>Better coordination. <em>Better outcomes.</em></h2>
        <p class="section-intro">Integrated, coordinated care produces meaningfully better health outcomes than fragmented care. The Collective is our practical response to that evidence.</p>
      </div>
      <div class="wc-why-grid">
        <div class="wc-why-card">
          <div class="wc-icon-box">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--green-500)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>Vetted, not random</h3>
          <p>Every Collective partner has been personally evaluated — so your first appointment doesn't begin with uncertainty about who you're seeing.</p>
        </div>
        <div class="wc-why-card">
          <div class="wc-icon-box">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--green-500)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3>No time wasted</h3>
          <p>Priority scheduling and direct physician communication mean less time waiting and re-explaining — more time on recovery and progress.</p>
        </div>
        <div class="wc-why-card">
          <div class="wc-icon-box">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--green-500)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3>A team around you</h3>
          <p>Rather than separate providers working in silos, the Collective functions as a coordinated team — all connected through your physician at the center.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── 4. WHAT MEMBERS RECEIVE ───────────────────────────── -->
  <section class="section wc-members wc-reveal">
    <div class="container wc-members-inner">
      <div class="wc-members-left">
        <span class="wc-members-label">Included in Membership</span>
        <h2 class="wc-members-h2">What members <em>receive.</em></h2>
        <p class="wc-members-desc">Access to the Wellness Collective is part of your Forward Family Medicine membership. There is no enrollment, no additional fee, and no separate sign-up.</p>
        <div class="wc-gold-badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="rgba(212,169,106,1)" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          Included with every FFM membership
        </div>
      </div>
      <div class="wc-members-right">
        <ol class="wc-numbered-list">
          <li>
            <span class="wc-num">01</span>
            <div>
              <h4 class="wc-num-h4">Physician-curated referrals</h4>
              <p class="wc-num-p">Your physician personally identifies the right partner based on your clinical needs — not a general search.</p>
            </div>
          </li>
          <li>
            <span class="wc-num">02</span>
            <div>
              <h4 class="wc-num-h4">Priority scheduling</h4>
              <p class="wc-num-p">Collective partners hold availability for FFM members, so you get in faster than a general patient would.</p>
            </div>
          </li>
          <li>
            <span class="wc-num">03</span>
            <div>
              <h4 class="wc-num-h4">Preferred member rates</h4>
              <p class="wc-num-p">Many partners — especially cash-based and independent practices — offer preferred pricing for our members.</p>
            </div>
          </li>
          <li>
            <span class="wc-num">04</span>
            <div>
              <h4 class="wc-num-h4">Direct physician communication</h4>
              <p class="wc-num-p">We contact Collective providers directly — sharing your history and goals before your first appointment.</p>
            </div>
          </li>
          <li>
            <span class="wc-num">05</span>
            <div>
              <h4 class="wc-num-h4">Closed-loop follow-up</h4>
              <p class="wc-num-p">After your appointment, we follow up and review progress at your next visit. Your care doesn't get handed off.</p>
            </div>
          </li>
        </ol>
      </div>
    </div>
  </section>

  <!-- ─── 5. AREAS OF CARE ──────────────────────────────────── -->
  <section class="section wc-areas wc-reveal">
    <div class="container">
      <div class="wc-section-header">
        <span class="section-label">Areas of Care</span>
        <h2>Eight categories. <em>One physician-led network.</em></h2>
        <p class="section-intro">The Collective spans the full range of wellness and specialty care — organized around how your health actually works.</p>
      </div>
      <div class="wc-areas-grid">
        <div class="wc-area-card">
          <div class="wc-icon-box">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green-500)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="5" r="2"/><path d="M12 7v5l-3 3"/><path d="M12 12l3 3"/><path d="M9 17l-2 3"/><path d="M15 17l2 3"/></svg>
          </div>
          <h3>Movement &amp; Rehabilitation</h3>
          <p class="wc-area-subtitle">Restoring and protecting function</p>
          <div class="wc-tags">
            <span class="wc-tag">Physical Therapy</span>
            <span class="wc-tag">Chiropractic Care</span>
            <span class="wc-tag">Manual Therapy</span>
          </div>
        </div>
        <div class="wc-area-card">
          <div class="wc-icon-box">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green-500)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
          </div>
          <h3>Performance &amp; Vitality</h3>
          <p class="wc-area-subtitle">Strength, fitness, and metabolic health</p>
          <div class="wc-tags">
            <span class="wc-tag">Personal Training</span>
            <span class="wc-tag">Fitness Coaching</span>
            <span class="wc-tag">Registered Dietitians</span>
            <span class="wc-tag">Nutrition Therapy</span>
          </div>
        </div>
        <div class="wc-area-card">
          <div class="wc-icon-box">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green-500)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 3a3 3 0 0 0-3 3v12a3 3 0 0 0 3 3 3 3 0 0 0 3-3 3 3 0 0 0-3-3H6a3 3 0 0 0-3 3 3 3 0 0 0 3 3 3 3 0 0 0 3-3V6a3 3 0 0 0-3-3 3 3 0 0 0-3 3 3 3 0 0 0 3 3h12a3 3 0 0 0 3-3 3 3 0 0 0-3-3z"/></svg>
          </div>
          <h3>Mind &amp; Recovery</h3>
          <p class="wc-area-subtitle">Sleep, mental health, and restoration</p>
          <div class="wc-tags">
            <span class="wc-tag">Mental Health Therapy</span>
            <span class="wc-tag">Sleep Medicine</span>
            <span class="wc-tag">Acupuncture</span>
            <span class="wc-tag">Detox &amp; Recovery</span>
          </div>
        </div>
        <div class="wc-area-card">
          <div class="wc-icon-box">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green-500)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </div>
          <h3>Skin &amp; Integrative Health</h3>
          <p class="wc-area-subtitle">Specialized skin and aesthetic care</p>
          <div class="wc-tags">
            <span class="wc-tag">Dermatology</span>
            <span class="wc-tag">Cosmetic Dermatology</span>
            <span class="wc-tag">Aesthetics</span>
          </div>
        </div>
        <div class="wc-area-card">
          <div class="wc-icon-box">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green-500)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>
          </div>
          <h3>Women's Health</h3>
          <p class="wc-area-subtitle">Reproductive, hormonal, and perinatal care</p>
          <div class="wc-tags">
            <span class="wc-tag">Midwifery / OB-GYN</span>
            <span class="wc-tag">Pelvic Floor PT</span>
            <span class="wc-tag">Postpartum Doulas</span>
            <span class="wc-tag">Perinatal Mood Disorder Therapists</span>
            <span class="wc-tag">Menopause / Hormone Specialists</span>
          </div>
        </div>
        <div class="wc-area-card">
          <div class="wc-icon-box">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green-500)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3>Children &amp; Family</h3>
          <p class="wc-area-subtitle">Development, nutrition, and family wellbeing</p>
          <div class="wc-tags">
            <span class="wc-tag">Speech-Language Pathology</span>
            <span class="wc-tag">Pediatric Dietitian</span>
            <span class="wc-tag">Lactation Consultants</span>
            <span class="wc-tag">Family / Child Therapists</span>
          </div>
        </div>
        <div class="wc-area-card">
          <div class="wc-icon-box">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green-500)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
          </div>
          <h3>Restore &amp; Recharge</h3>
          <p class="wc-area-subtitle">Recovery, relaxation, and cellular renewal</p>
          <div class="wc-tags">
            <span class="wc-tag">Massage Therapy</span>
            <span class="wc-tag">Infrared Sauna</span>
            <span class="wc-tag">Acupuncture</span>
            <span class="wc-tag">Breathwork / Meditation Instructor</span>
            <span class="wc-tag">Red Light Therapy</span>
          </div>
        </div>
        <div class="wc-area-card">
          <div class="wc-icon-box">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green-500)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <h3>Metabolic Health &amp; Longevity</h3>
          <p class="wc-area-subtitle">Physician-interpreted diagnostics for a longer, stronger life</p>
          <div class="wc-tags">
            <span class="wc-tag">Body Composition &amp; Bone Density</span>
            <span class="wc-tag">VO₂ Max Testing</span>
            <span class="wc-tag">Advanced Lipid Panels</span>
            <span class="wc-tag">Coronary Artery Calcium Scoring</span>
            <span class="wc-tag">Continuous Glucose Monitoring</span>
            <span class="wc-tag">Multi-Cancer Early Detection</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── 6. HOW IT WORKS ───────────────────────────────────── -->
  <section class="section wc-how wc-reveal">
    <div class="container">
      <div class="wc-section-header">
        <span class="section-label">How It Works</span>
        <h2>Three steps. <em>No guesswork.</em></h2>
      </div>
      <div class="wc-steps">
        <div class="wc-connector" aria-hidden="true"></div>
        <div class="wc-step">
          <div class="wc-step-circle">
            <span class="wc-step-num" aria-hidden="true">1</span>
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </div>
          <h3>Discuss with your physician</h3>
          <p>Mention a concern, a goal, or something you want addressed outside primary care. Your physician assesses what kind of partner makes sense.</p>
        </div>
        <div class="wc-step">
          <div class="wc-step-circle">
            <span class="wc-step-num" aria-hidden="true">2</span>
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </div>
          <h3>Get matched and connected</h3>
          <p>We identify the right Collective partner for your situation and make a direct introduction — with your clinical context shared upfront.</p>
        </div>
        <div class="wc-step">
          <div class="wc-step-circle">
            <span class="wc-step-num" aria-hidden="true">3</span>
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <h3>Receive coordinated care</h3>
          <p>Your physician stays informed throughout. Progress is reviewed at your next visit. Nothing gets lost between providers.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── 7. COORDINATED BY DESIGN ─────────────────────────── -->
  <section class="section wc-orbit-section wc-reveal">
    <div class="container wc-orbit-inner">
      <div class="wc-orbit-wrap">
        <div class="wc-orbit">
          <!-- Center -->
          <div class="wc-orbit-center">
            <span>Your</span>
            <span>physician</span>
          </div>
          <!-- Rings -->
          <div class="wc-ring wc-ring-inner" aria-hidden="true"></div>
          <div class="wc-ring wc-ring-outer" aria-hidden="true"></div>
          <!-- Inner ring nodes (N/E/S/W at 110px) -->
          <div class="wc-node wc-node-top" aria-label="Physical Therapy">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--green-400)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
            <span>PT</span>
          </div>
          <div class="wc-node wc-node-right" aria-label="Fitness">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--green-400)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            <span>Fitness</span>
          </div>
          <div class="wc-node wc-node-bottom" aria-label="Sleep Medicine">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--green-400)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
            <span>Sleep</span>
          </div>
          <div class="wc-node wc-node-left" aria-label="Dermatology">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--green-400)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="5"/><path d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
            <span>Derm</span>
          </div>
