    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }
  .wc-step h3 {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--ink-900);
    margin-bottom: 0.6rem;
  }
  .wc-step p {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 0.87rem;
    color: var(--ink-500);
    line-height: 1.65;
    margin: 0;
    max-width: 240px;
  }

  /* ─── Coordinated by Design ─────────────────────────────── */
  .wc-orbit-section {
    background: #ffffff;
    border-top: 1px solid var(--cream-200);
  }
  .wc-orbit-inner {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 80px;
    align-items: center;
  }
  .wc-orbit-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .wc-orbit {
    position: relative;
    width: 400px;
    height: 400px;
    max-width: 400px;
    aspect-ratio: 1;
    flex-shrink: 0;
  }
  .wc-orbit-center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 118px;
    height: 118px;
    background: var(--green-500);
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 0.9rem;
    color: #ffffff;
    line-height: 1.3;
    text-align: center;
    box-shadow:
      0 0 0 12px rgba(63,99,68,0.10),
      0 0 0 24px rgba(63,99,68,0.05);
    z-index: 2;
  }
  .wc-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    border-radius: 50%;
    border: 1px dashed rgba(90,136,96,0.35);
  }
  .wc-ring-inner {
    width: 220px;
    height: 220px;
    transform: translate(-50%, -50%) rotate(0deg);
    animation: orbit-spin 26s linear infinite;
  }
  .wc-ring-outer {
    width: 338px;
    height: 338px;
    transform: translate(-50%, -50%) rotate(0deg);
    animation: orbit-spin-rev 42s linear infinite;
  }
  @keyframes orbit-spin {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to   { transform: translate(-50%, -50%) rotate(360deg); }
  }
  @keyframes orbit-spin-rev {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to   { transform: translate(-50%, -50%) rotate(-360deg); }
  }
  /* Node base */
  .wc-node {
    position: absolute;
    width: 54px;
    height: 54px;
    background: #ffffff;
    border: 1px solid var(--cream-300);
    border-radius: var(--radius-sm);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3px;
    z-index: 3;
  }
  .wc-node span {
    font-family: var(--font-body);
    font-size: 0.54rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--ink-500);
    line-height: 1;
  }
  /* Inner ring (110px from center, 27px = half node size) */
  .wc-node-top    { top: calc(50% - 137px); left: calc(50% - 27px); }
  .wc-node-right  { top: calc(50% - 27px);  left: calc(50% + 83px);  }
  .wc-node-bottom { top: calc(50% + 83px);  left: calc(50% - 27px);  }
  .wc-node-left   { top: calc(50% - 27px);  left: calc(50% - 137px); }
  /* Outer ring (119px from center, diagonal) */
  .wc-node-ne { top: calc(50% - 146px); left: calc(50% + 92px);  }
  .wc-node-se { top: calc(50% + 92px);  left: calc(50% + 92px);  }
  .wc-node-sw { top: calc(50% + 92px);  left: calc(50% - 146px); }
  .wc-node-nw { top: calc(50% - 146px); left: calc(50% - 146px); }

  /* Right column */
  .wc-orbit-right h2 em { color: var(--green-500); font-style: italic; }
  .wc-integration-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 1.75rem;
  }
  .wc-integration-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }
  .wc-dot {
    width: 8px;
    height: 8px;
    background: var(--green-500);
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 7px;
  }
  .wc-integration-item p {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 0.92rem;
    color: var(--ink-500);
    line-height: 1.75;
    margin: 0;
  }
  .wc-integration-item p strong {
    font-weight: 600;
    color: var(--ink-900);
  }

  /* ─── Mobile ─────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .wc-botanical { display: none; }
  }

  @media (max-width: 900px) {
    .wc-hero-inner {
      grid-template-columns: 1fr;
    }
    .wc-what-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .wc-why-grid {
      grid-template-columns: 1fr;
    }
    .wc-members-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .wc-areas-grid {
      grid-template-columns: 1fr;
    }
    .wc-steps {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      margin-top: 2rem;
    }
    .wc-connector { display: none; }
    .wc-step { align-items: flex-start; text-align: left; }
    .wc-step p { max-width: none; }
    .wc-orbit-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .wc-orbit {
      max-width: 300px;
      width: 300px;
      height: 300px;
      margin: 0 auto;
    }
    .wc-orbit-center {
      width: 90px;
      height: 90px;
      font-size: 0.78rem;
    }
    .wc-ring-inner  { width: 165px; height: 165px; }
    .wc-ring-outer  { width: 254px; height: 254px; }
    .wc-node-top    { top: calc(50% - 110px); left: calc(50% - 27px); }
    .wc-node-right  { top: calc(50% - 27px);  left: calc(50% + 55px); }
    .wc-node-bottom { top: calc(50% + 55px);  left: calc(50% - 27px); }
    .wc-node-left   { top: calc(50% - 27px);  left: calc(50% - 110px); }
    .wc-node-ne { top: calc(50% - 115px); left: calc(50% + 60px); }
    .wc-node-se { top: calc(50% + 60px);  left: calc(50% + 60px); }
    .wc-node-sw { top: calc(50% + 60px);  left: calc(50% - 115px); }
    .wc-node-nw { top: calc(50% - 115px); left: calc(50% - 115px); }
  }
</style>

<script>
  // ─── Scroll reveal ────────────────────────────────────────
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('wc-reveal--visible');
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.10 }
  );

  document.querySelectorAll('.wc-reveal').forEach((el) => {
    revealObserver.observe(el);
  });
</script>
