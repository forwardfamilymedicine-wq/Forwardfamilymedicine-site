    background-image: url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='20' cy='20' r='3' fill='none' stroke='%233F6344' stroke-width='0.8'/%3E%3Cline x1='20' y1='13' x2='20' y2='16' stroke='%233F6344' stroke-width='0.8'/%3E%3Cline x1='20' y1='24' x2='20' y2='27' stroke='%233F6344' stroke-width='0.8'/%3E%3Cline x1='13' y1='20' x2='16' y2='20' stroke='%233F6344' stroke-width='0.8'/%3E%3Cline x1='24' y1='20' x2='27' y2='20' stroke='%233F6344' stroke-width='0.8'/%3E%3C/svg%3E");
    background-repeat: repeat;
