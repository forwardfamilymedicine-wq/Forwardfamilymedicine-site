---
import MainLayout from '../layouts/MainLayout.astro';
import FAQSection from '../components/shared/FAQSection.astro';
import CTABanner from '../components/shared/CTABanner.astro';

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.forwardfamilymedicine.com" },
    { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://www.forwardfamilymedicine.com/services" }
  ]
};

const clinicSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalClinic",
  "name": "Forward Family Medicine",
  "url": "https://www.forwardfamilymedicine.com",
  "telephone": "+12156457044",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "295 Old Eagle School Road",
    "addressLocality": "Wayne",
    "addressRegion": "PA",
    "postalCode": "19087",
    "addressCountry": "US"
  },
  "medicalSpecialty": ["FamilyMedicine", "LifestyleMedicine"]
};

const faqs = [
  {
    q: 'Do I need insurance to be a patient?',
    a: 'No. Our DPC membership covers your primary care needs directly — no insurance required. We recommend pairing it with a high-deductible health plan or health sharing plan for hospitalizations and specialist care.',
  },
  {
    q: 'What does a DPC membership actually include?',
    a: 'Unlimited office visits with no copay, same-day and next-day appointments, visits of 1–2 hours, direct phone/text/email access to your doctor, preventive care, chronic disease management, minor in-office procedures, wholesale lab pricing, telehealth, and specialist referral coordination.',
  },
  {
    q: 'Is Lifestyle Medicine a separate service or add-on?',
    a: "Lifestyle medicine is fully integrated into Dr. Lieberman's practice — not a separate fee or add-on. It's part of what your membership covers. Dr. Lieberman is dual board-eligible in Family Medicine and Lifestyle Medicine.",
  },
  {
    q: 'What is Concierge Medicine vs DPC?',
    a: 'At Forward Family Medicine, there is no separate concierge tier. Every member receives the full concierge experience — small panel, direct doctor access, unhurried visits — through the DPC membership. It is the standard, not an upgrade.',
  },
];
---

<MainLayout
  title="DPC + Lifestyle Medicine Services | Forward Family Medicine Wayne PA"
  description="Direct Primary Care, board-eligible Lifestyle Medicine, and Concierge Medicine in Wayne PA. Flat monthly membership. No insurance. Serving the Main Line and Chester County."
  schema={[breadcrumb, clinicSchema]}
>
  <!-- Page hero -->
  <section class="page-hero section hero-section">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a> <span aria-hidden="true">›</span> <span>Services</span>
      </nav>
      <span class="section-label">What We Offer</span>
      <h1 class="hero-h1">Services Designed Around You, Not Your Insurance</h1>
      <div class="divider"></div>
      <p class="section-intro">
        At Forward Family Medicine, every membership includes three things at once: the financial
        transparency of Direct Primary Care, the personal attention of concierge medicine, and the
        clinical depth of board-eligible Lifestyle Medicine. These aren't separate services or tiers.
        They're three dimensions of the same practice — and every member gets all three.
      </p>
    </div>
  </section>

  <!-- Stats strip -->
  <section class="stats-strip">
    <div class="container">
      <p class="stats-eyebrow">Why DPC Changes Everything</p>
      <div class="stats-compare">
        <!-- Column headers -->
        <div class="stats-col-headers">
          <div class="stats-col-header stats-col-header--trad">Traditional Care</div>
          <div class="stats-col-header stats-col-header--ffm">Forward Family Medicine</div>
        </div>
        <!-- Row: Appointment time -->
        <div class="stats-row">
          <p class="stats-row-label">Average Appointment Time</p>
          <div class="stats-row-cells">
            <div class="stats-cell stats-cell--trad">
              <span class="stats-val stats-val--trad">7 min</span>
            </div>
            <div class="stats-cell stats-cell--ffm">
              <span class="stats-val stats-val--ffm">1–2 hrs</span>
            </div>
          </div>
        </div>
        <!-- Row: Patients per doctor -->
        <div class="stats-row">
          <p class="stats-row-label">Patients Per Doctor</p>
          <div class="stats-row-cells">
            <div class="stats-cell stats-cell--trad">
              <span class="stats-val stats-val--trad">2,000–3,000</span>
            </div>
            <div class="stats-cell stats-cell--ffm">
              <span class="stats-val stats-val--ffm">~250</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DPC -->
  <section class="service-detail section dpc-section" id="dpc">
    <div class="container">
      <div class="service-detail-inner">
        <div class="service-detail-content">
          <span class="section-label">Primary Service</span>
          <h2>Direct Primary Care</h2>
          <div class="divider"></div>
          <p>
            Direct Primary Care is the financial model that makes everything else possible. No
            insurance billing. No copays. No per-visit fees. Your membership covers unlimited
            primary care, and because we don't bill insurance, our overhead is low — which means
            we can pass real savings to you. Labs at wholesale. Medications at cost. Same-day
            access that keeps you out of urgent care. This is primary care that is actively trying
            to lower what healthcare costs you.
          </p>
          <p>
            At Forward Family Medicine, your DPC membership means unlimited primary care with
            no copay, same-day appointments, and direct access to your doctor via phone, text,
            or email. Not through a nurse line. Your doctor.
          </p>

          <h3>What's Included</h3>
          <ul class="prose-list service-list">
            <li>Unlimited office visits — no copay, no per-visit fees</li>
            <li>Same-day and next-day appointments</li>
            <li>Visits: 1–2 hours</li>
            <li>Direct access to your doctor: phone, text, and email</li>
            <li>Preventive care and annual wellness exams</li>
            <li>Chronic disease management (diabetes, hypertension, thyroid, etc.)</li>
            <li>Minor in-office procedures</li>
            <li>Wholesale lab and medication pricing</li>
            <li>Telehealth visits included</li>
            <li>Specialist referral coordination</li>
            <li>Integrated Lifestyle Medicine (with Dr. Lieberman)</li>
          </ul>

          <div class="callout callout-accent" style="margin-top:1.75rem;">
            <strong>Important:</strong> DPC membership is not insurance. It covers your
            day-to-day primary care. We recommend pairing it with a high-deductible health
            plan or health sharing plan for hospitalizations, surgeries, and specialist care.
          </div>

          <div class="service-ctas">
            <a href="/membership" class="btn btn-primary">See Membership Options</a>
            <a href="/contact" class="btn btn-outline">Schedule a Free Meet &amp; Greet</a>
          </div>
        </div>
        <div class="service-detail-aside">
          <div class="card aside-card" style="background: linear-gradient(135deg,var(--green-50),var(--cream-200)); border:2px solid var(--green-300);">
            <h4>Lifestyle Medicine Included</h4>
            <p style="font-size:0.9rem; color:var(--ink-700); margin-bottom:1rem;">Every DPC membership includes access to Dr. Lieberman's Lifestyle Medicine practice. Nutrition, movement, sleep, and stress — treated as medicine.</p>
            <a href="/lifestyle-medicine" class="btn btn-primary" style="font-size:0.85rem; padding:0.6rem 1.25rem;">Learn More →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Lifestyle Medicine teaser -->
  <section class="service-detail section lm-section" id="lifestyle-medicine">
    <div class="container">
      <span class="section-label">Our Differentiator</span>
      <h2>Lifestyle Medicine</h2>
      <div class="divider"></div>
      <div class="grid-2">
        <div>
          <p>
            Forward Family Medicine is the only DPC practice on the Main Line offering
            in-person, board-eligible Lifestyle Medicine. Dr. Lieberman is dual board-eligible
            in Family Medicine and Lifestyle Medicine, with pre-medical training in culinary
            arts and nutrition science.
          </p>
          <p>
            Lifestyle medicine treats chronic disease at its root — through evidence-based
            changes in nutrition, physical activity, sleep, stress management, and social
            connection. At FFM, it's not a handout at the end of your visit. It's integrated
            into how we practice.
          </p>
          <a href="/lifestyle-medicine" class="btn btn-primary">View Full Lifestyle Medicine Page →</a>
        </div>
        <div>
          <ul class="dot-list">
            <li>Comprehensive lifestyle assessment</li>
            <li>Personalized nutrition guidance — culinary-informed, practical</li>
            <li>Physical activity planning</li>
            <li>Sleep optimization protocols</li>
            <li>Stress and mental wellness support</li>
            <li>Evidence-based protocols for diabetes, hypertension, heart health, obesity</li>
            <li>Ongoing accountability built into your membership</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Concierge -->
  <section class="service-detail section concierge-section" id="concierge">
    <div class="container">
      <span class="section-label">Premium Care</span>
      <h2>Concierge Medicine</h2>
      <div class="divider"></div>
      <div class="grid-2">
        <div>
          <p>
            There is no separate concierge tier at Forward Family Medicine. Every member receives
            what the industry calls a concierge experience — a physician whose panel is capped at
            250 patients, who picks up the phone, who runs 1–2 hour visits, and who
            follows up without being asked. This is not a premium add-on. It is the standard.
          </p>
          <a href="/concierge-medicine" class="btn btn-primary">Learn more about the concierge experience at FFM →</a>
        </div>
        <div></div>
      </div>
    </div>
  </section>

  <!-- ── Wellness Collective Teaser ───────────────────────── -->
  <section class="wc-teaser">
    <div class="container">
      <div class="wc-teaser__grid">

        <div class="wc-teaser__left">
          <div class="wc-teaser__badge">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><circle cx="7" cy="7" r="6" stroke="var(--green-500)" stroke-width="1.25"/><polyline points="4,7 6,9.5 10,4.5" stroke="var(--green-500)" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Included in every membership
          </div>
          <p class="wc-teaser__eyebrow">The Wellness Collective</p>
          <h2 class="wc-teaser__heading">
            Care that extends beyond our office.
          </h2>
          <p class="wc-teaser__body">
            Membership at Forward Family Medicine includes access to the
            Main Line Wellness Collective — a curated network of best-in-class
            local providers across physical therapy, nutrition, fitness, mental
            health, dermatology, sleep medicine, and more.
          </p>
          <p class="wc-teaser__body">
            Every provider has been personally vetted by your physician. When
            you need a referral, we match you, make the connection, and
            coordinate your care — so nothing falls through the cracks.
          </p>
          <a href="/wellness-collective" class="wc-teaser__link">
            See the full Collective
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><line x1="2" y1="7" x2="12" y2="7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><polyline points="8,3 12,7 8,11" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>

        <div class="wc-teaser__cards">
          <div class="wc-teaser__card">
            <div class="wc-teaser__card-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--green-500)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h4>Physician-vetted</h4>
            <p>Every partner is individually reviewed — not sourced from a database.</p>
          </div>
          <div class="wc-teaser__card">
            <div class="wc-teaser__card-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--green-500)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <h4>Priority access</h4>
            <p>Collective partners reserve availability for FFM members.</p>
          </div>
          <div class="wc-teaser__card">
            <div class="wc-teaser__card-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--green-500)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <h4>Coordinated care</h4>
            <p>Your physician communicates directly with every referral partner.</p>
          </div>
          <div class="wc-teaser__card">
            <div class="wc-teaser__card-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--green-500)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <h4>Member pricing</h4>
            <p>Many partners offer preferred rates exclusively for our members.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <FAQSection faqs={faqs} headline="Questions About Our Services" />
  <CTABanner />
</MainLayout>

<style>
  /* ── Hero ─────────────────────────────────────────────────── */
  .hero-section {
    background: var(--cream-100);
  }
  .hero-h1 {
    font-size: clamp(2.4rem, 5.5vw, 3.75rem);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 1.25rem;
  }

  /* ── Stats strip ─────────────────────────────────────────── */
  .stats-strip {
    background: var(--green-300);
    padding: clamp(36px, 6vw, 60px) 0;
  }
  .stats-eyebrow {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.75);
    margin-bottom: 1.5rem;
  }
  /* Comparison table */
  .stats-compare {
    max-width: 680px;
  }
  /* Column header row */
  .stats-col-headers {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 0.5rem;
    padding: 0 0 0 calc(0px);
  }
  .stats-col-header {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.4rem 1rem;
    border-radius: 4px;
    text-align: center;
  }
  .stats-col-header--trad {
    color: rgba(255,255,255,0.5);
    border: 1px solid rgba(255,255,255,0.15);
    background: rgba(255,255,255,0.04);
  }
  .stats-col-header--ffm {
    color: var(--green-100);
    border: 1px solid rgba(167,204,169,0.35);
    background: rgba(167,204,169,0.10);
  }
  /* Each metric row */
  .stats-row {
    margin-bottom: 1.75rem;
  }
  .stats-row:last-child {
    margin-bottom: 0;
  }
  .stats-row-label {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    margin-bottom: 0.5rem;
  }
  .stats-row-cells {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .stats-cell {
    padding: 1rem 1rem 1rem 1rem;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .stats-cell--trad {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
  }
  .stats-cell--ffm {
    background: rgba(167,204,169,0.12);
    border: 1px solid rgba(167,204,169,0.3);
  }
  .stats-val {
    font-family: var(--font-heading);
    line-height: 1.1;
    display: block;
  }
  .stats-val--trad {
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    font-weight: 400;
    color: rgba(255,255,255,0.45);
  }
  .stats-val--ffm {
    font-size: clamp(1.9rem, 4vw, 2.75rem);
    font-weight: 700;
    color: var(--green-100);
  }
  @media (max-width: 480px) {
    .stats-compare {
      max-width: 100%;
    }
  }

  /* ── DPC section ─────────────────────────────────────────── */
  .dpc-section {
    background: #ffffff;
  }

  /* ── Lifestyle Medicine section ──────────────────────────── */
  .lm-section {
    background: var(--cream-200);
  }
  .dot-list {
    list-style: none;
    padding: 0;
  }
  .dot-list li {
    padding: 0.5rem 0 0.5rem 1.75rem;
    position: relative;
    line-height: 1.55;
  }
  .dot-list li::before {
    content: '●';
    position: absolute;
    left: 0;
    color: var(--green-300);
    font-size: 0.65rem;
    top: 0.7rem;
  }

  /* ── Concierge section ───────────────────────────────────── */
  .concierge-section {
    background: #ffffff;
  }

  /* ── Breadcrumb ──────────────────────────────────────────── */
  .breadcrumb {
    font-size: 0.85rem;
    color: var(--ink-300);
    margin-bottom: 1.5rem;
  }
  .breadcrumb a { color: var(--green-300); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }

  /* ── DPC layout ──────────────────────────────────────────── */
  .service-detail-inner {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 3rem;
    align-items: start;
  }
  .service-list {
    margin-top: 0.75rem;
  }
  .service-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  @media (max-width: 900px) {
    .service-detail-inner {
      grid-template-columns: 1fr;
    }
  }

  /* ── Wellness Collective Teaser ──────────────────────────── */
  .wc-teaser {
    background: var(--cream-200);
    padding: var(--section-pad) 0;
    border-top: 1px solid var(--cream-300);
  }
  .wc-teaser__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }
  .wc-teaser__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 5px 14px;
    background: rgba(63,99,68,0.08);
    border: 1px solid rgba(63,99,68,0.2);
    border-radius: 40px;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--green-500);
    margin-bottom: 16px;
  }
  .wc-teaser__eyebrow {
    font-size: 0.73rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--green-500);
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }
  .wc-teaser__eyebrow::before {
    content: '';
    width: 24px;
    height: 1px;
    background: var(--green-500);
    flex-shrink: 0;
  }
  .wc-teaser__heading {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 400;
    color: var(--ink-900);
    line-height: 1.2;
    margin-bottom: 16px;
    letter-spacing: -0.01em;
  }
  .wc-teaser__body {
    font-size: 0.95rem;
    font-weight: 300;
    line-height: 1.82;
    color: var(--ink-700);
    margin-bottom: 12px;
  }
  .wc-teaser__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 20px;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--green-500);
    text-decoration: none;
    border-bottom: 1px solid var(--green-200);
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s, gap 0.2s;
  }
  .wc-teaser__link:hover {
    color: var(--green-400);
    border-color: var(--green-500);
    gap: 12px;
  }
  .wc-teaser__cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .wc-teaser__card {
    background: #ffffff;
    border: 1px solid var(--cream-300);
    border-radius: var(--radius);
    padding: 22px 20px;
    transition: transform 0.22s, box-shadow 0.22s, border-color 0.22s;
  }
  .wc-teaser__card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--green-300);
  }
  .wc-teaser__card-icon {
    width: 36px;
    height: 36px;
    background: var(--green-50);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
  }
  .wc-teaser__card h4 {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 500;
    color: var(--ink-900);
    margin-bottom: 5px;
  }
  .wc-teaser__card p {
    font-size: 0.82rem;
    font-weight: 300;
    line-height: 1.65;
    color: var(--ink-500);
    margin: 0;
  }
  @media (max-width: 900px) {
    .wc-teaser__grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
  @media (max-width: 480px) {
    .wc-teaser__cards {
      grid-template-columns: 1fr;
    }
  }
</style>
