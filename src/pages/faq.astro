---
import MainLayout from '../layouts/MainLayout.astro';

const faqGroups = [
  {
    id: 'about',
    title: 'About Forward Family Medicine',
    faqs: [
      {
        q: 'What is Forward Family Medicine?',
        a: 'Forward Family Medicine is a Direct Primary Care (DPC) practice in Wayne, PA. We provide comprehensive primary care on a membership model: you pay a flat monthly fee, and in return you receive unlimited primary care visits, direct access to your physician, longer appointments, and wholesale lab pricing — with no copays or insurance billing for covered services. <a href="/about">Learn more about our practice →</a>',
      },
      {
        q: 'Where are you located?',
        a: 'We are located in Wayne, Pennsylvania, on the Philadelphia Main Line at 295 Old Eagle School Road, Wayne, PA 19087. <a href="/contact">See our location and contact info →</a>',
      },
      {
        q: 'Who are the physicians at Forward Family Medicine?',
        a: 'Dr. David Bigley is the founder of Forward Family Medicine, a board-certified Family Medicine physician, and a Doctor of Osteopathic Medicine (DO). Dr. Philip Lieberman is dual board-eligible in Family Medicine and Lifestyle Medicine, with a culinary arts background that makes nutrition advice actually practical. <a href="/about">Meet the team →</a>',
      },
      {
        q: 'Are you currently accepting new patients?',
        a: 'Yes — we are actively enrolling new members. Our patient panel is intentionally small, so we encourage you to <a href="/contact">schedule a Meet & Greet →</a> before we reach capacity.',
      },
    ],
  },
  {
    id: 'dpc',
    title: 'About Direct Primary Care',
    faqs: [
      {
        q: 'What is Direct Primary Care (DPC)?',
        a: 'Direct Primary Care is a membership-based model of primary care in which patients pay a flat monthly fee directly to their physician — bypassing insurance for primary care services. In exchange, members receive unlimited visits, direct physician access, and longer appointments. At Forward Family Medicine, our panel is capped at 250 patients per physician — versus 2,000+ in traditional practices. <a href="/direct-primary-care">Full DPC explainer →</a>',
      },
      {
        q: 'How is DPC different from concierge medicine?',
        a: 'Both models offer smaller panels, direct access, and longer visits. The key difference: traditional concierge medicine typically charges a higher annual retainer and may still bill insurance. DPC does not bill insurance for primary care and charges a lower flat monthly fee — making it more accessible. <a href="/concierge-medicine">See the full comparison →</a>',
      },
      {
        q: 'Is DPC legal?',
        a: 'Yes. DPC is legal in all 50 states. Many states have passed legislation explicitly affirming that DPC membership agreements are not insurance products and do not require an insurance license to operate.',
      },
      {
        q: 'How many patients do your physicians see per day?',
        a: 'We schedule based on need, not volume. On a typical day, Dr. Bigley and Dr. Lieberman may see 6–12 patients — compared to 20–30 in a traditional practice. This is what enables longer appointments, same-day access, and real follow-through on care.',
      },
    ],
  },
  {
    id: 'pricing',
    title: 'Membership & Pricing',
    faqs: [
      {
        q: 'What does a membership cost?',
        a: 'Individual membership is $200/month. Family membership starts at $175/person/month for two members and scales to $100/person/month for five or more. There is no enrollment fee. <a href="/membership">See full membership details and pricing →</a>',
      },
      {
        q: 'What does the monthly membership include?',
        a: 'Your membership covers unlimited primary care visits (in-person, video, and phone), direct physician access, preventive care, chronic disease management, lifestyle medicine counseling, same-day/next-day scheduling, and minor in-office procedures. Labs and medications are available at wholesale/near-cost pricing as separate add-ons. <a href="/services">See full service list →</a>',
      },
      {
        q: 'Are there any copays or per-visit fees?',
        a: 'No. Once you are a member, there are no additional fees for covered visits. The only charges beyond your membership are for labs, medications, and immunizations — all priced at cost.',
      },
      {
        q: 'Is there a long-term commitment?',
        a: 'We offer both month-to-month and annual membership options. Month-to-month plans require 30 days\' written notice to cancel. Annual plans include a modest discount.',
      },
      {
        q: 'Is there an enrollment fee?',
        a: 'At Forward Family Medicine, there is no enrollment fee.',
      },
      {
        q: 'Can I use my HSA or FSA for membership fees?',
        a: 'Yes. DPC membership fees became HSA-eligible on January 1, 2026 under the Primary Care Enhancement Act, which clarified that HSA funds can be used for DPC memberships. We recommend confirming eligibility with your plan administrator, as individual plan rules may vary. Most other health-related expenses at our practice — labs, medications, and in-office procedures — are also HSA-eligible.',
      },
      {
        q: 'Do you offer employer group memberships?',
        a: 'Yes. We work with small and mid-size employers to offer DPC memberships as a health benefit. <a href="/for-businesses">Contact us to discuss employer options →</a>',
      },
    ],
  },
  {
    id: 'insurance',
    title: 'Insurance',
    faqs: [
      {
        q: 'Do I still need health insurance if I join a DPC practice?',
        a: 'Yes — we recommend it. Your DPC membership provides comprehensive primary care but does not cover hospital stays, emergency care, specialist visits, surgery, or imaging. We strongly recommend maintaining a health insurance plan — ideally a high-deductible health plan (HDHP) paired with an HSA — for these scenarios.',
      },
      {
        q: 'Will you bill my insurance for visits?',
        a: 'No. We do not bill insurance for primary care services. Your membership fee is the only charge for covered visits. Some members choose to submit their own claims for out-of-network reimbursement — check with your insurer.',
      },
      {
        q: 'Is DPC covered by Medicare or Medicaid?',
        a: 'DPC membership fees are not reimbursed by Medicare or Medicaid. Medicare and Medicaid beneficiaries are welcome to join as self-pay members. Specialist and hospital services would still be billed through Medicare or Medicaid as appropriate.',
      },
      {
        q: 'Can I use my insurance for labs and imaging ordered by your practice?',
        a: 'If you have insurance, you can choose to use it for labs and imaging. However, our wholesale lab pricing is often lower than your insurance-adjusted rate — we\'ll help you compare and choose.',
      },
    ],
  },
  {
    id: 'appointments',
    title: 'Appointments & Access',
    faqs: [
      {
        q: 'How quickly can I get an appointment?',
        a: 'Members typically get same-day or next-day appointments for acute concerns. Routine visits can be scheduled within 24–48 hours. Many concerns are resolved by phone or message without any in-person visit.',
      },
      {
        q: 'Can I contact my doctor between visits?',
        a: 'Yes. Members have direct access to Dr. Bigley and Dr. Lieberman via phone, text, and secure messaging. You will not reach an answering service or a nurse line.',
      },
      {
        q: 'What are your office hours?',
        a: 'Monday–Friday, 8:00 AM – 5:00 PM. For urgent matters, members have after-hours contact access for true clinical urgency — not prescription refills or routine requests.',
      },
      {
        q: 'What if I have a medical emergency?',
        a: 'Always call 911 or go to the nearest emergency room for life-threatening emergencies. Your DPC membership is for primary care — not emergency or hospital care.',
      },
      {
        q: 'Do you offer telehealth visits?',
        a: 'Yes. Phone and video visits are included in your membership. Many concerns — prescription refills, minor illness, result review, follow-up — can be handled without coming in.',
      },
    ],
  },
  {
    id: 'services',
    title: 'Services & Scope',
    faqs: [
      {
        q: 'Do you see children?',
        a: 'Yes. We provide care for patients of all ages, from newborns through older adults. Children can be added to a family membership. <a href="/membership">See membership options →</a>',
      },
      {
        q: 'Can you manage my chronic conditions?',
        a: 'Yes. Chronic disease management — diabetes, hypertension, thyroid disease, cholesterol, asthma, and more — is a core part of what we do. The DPC model is particularly well-suited for chronic disease management because it provides the time and continuity these conditions require.',
      },
      {
        q: 'Do you provide mental health care?',
        a: 'We screen for and treat common mental health conditions including depression and anxiety, and provide medication management. For therapy and psychiatric care, we maintain strong referral relationships and help coordinate access.',
      },
      {
        q: 'Can you be my primary care physician even if I have specialists?',
        a: 'Absolutely. We work alongside your specialists and serve as the coordinating physician for your overall care — reviewing specialist notes, reconciling medications, and keeping your care integrated.',
      },
      {
        q: 'Do you do physicals and well-woman exams?',
        a: 'Yes. Annual physicals, well-woman exams, and preventive health screenings are core services included in your membership.',
      },
      {
        q: 'What procedures can you do in-office?',
        a: 'We perform a range of minor procedures: EKGs, ear lavage, wound care, joint injections, skin tag removal, suturing, spirometry, and more. <a href="/services">See full procedures list →</a>',
      },
    ],
  },
  {
    id: 'lifestyle',
    title: 'Lifestyle Medicine',
    faqs: [
      {
        q: 'What is lifestyle medicine and is it included in my membership?',
        a: 'Lifestyle medicine uses evidence-based behavioral interventions — nutrition, physical activity, sleep, stress management — to prevent and treat chronic disease. It is integrated into every membership at no additional cost. <a href="/lifestyle-medicine">Learn more →</a>',
      },
      {
        q: 'Do you have a specific diet you recommend?',
        a: 'We don\'t prescribe one-size-fits-all diets. We use evidence-based guidance — drawing on Mediterranean, DASH, whole-food plant-based, and other well-studied approaches — tailored to your health goals and preferences.',
      },
    ],
  },
  {
    id: 'getting-started',
    title: 'Getting Started',
    faqs: [
      {
        q: 'How do I become a patient?',
        a: 'The first step is a free, no-obligation Meet & Greet with Dr. Bigley and Dr. Lieberman. <a href="/contact">Schedule yours here →</a>',
      },
      {
        q: 'What happens at the Meet & Greet?',
        a: 'It\'s a 20-minute conversation — in person or by video — where you can ask questions, learn about the practice, and decide whether Forward Family Medicine is right for you. No pressure, no commitment.',
      },
      {
        q: 'How long does enrollment take?',
        a: 'Online enrollment takes about 10 minutes. Your first comprehensive visit is typically scheduled within the first week or two of enrollment.',
      },
      {
        q: 'What do I need to bring to my first appointment?',
        a: 'A list of your current medications, any recent lab results or medical records, and any questions or concerns you\'d like to address. We\'ll have reviewed your submitted health history before you arrive.',
      },
    ],
  },
];
---

<MainLayout
  title="Frequently Asked Questions | Forward Family Medicine Wayne, PA"
  description="Answers to the most common questions about Direct Primary Care, DPC membership, what's included, insurance, pricing, and how Forward Family Medicine works in Wayne, PA."
  canonical="https://www.forwardfamilymedicine.com/faq"
>

  <!-- ─── Hero ──────────────────────────────────────────────────── -->
  <section class="page-hero">
    <div class="container">
      <p class="hero-eyebrow">Wayne, PA · Philadelphia Main Line</p>
      <h1>Frequently Asked Questions</h1>
      <p class="hero-desc">Everything you want to know about Forward Family Medicine and Direct Primary Care — answered plainly. If you don't see your question here, <a href="/contact" class="hero-link">reach out directly →</a></p>
    </div>
  </section>

  <!-- ─── Quick Nav ─────────────────────────────────────────────── -->
  <nav class="faq-nav" aria-label="Jump to FAQ section">
    <div class="container">
      <ul class="faq-nav-list">
        {faqGroups.map(g => (
          <li><a href={`#${g.id}`}>{g.title}</a></li>
        ))}
      </ul>
    </div>
  </nav>

  <!-- ─── FAQ Groups ────────────────────────────────────────────── -->
  {faqGroups.map((group, gi) => (
    <section id={group.id} class={`faq-group-section ${gi % 2 === 0 ? '' : 'section-alt'}`}>
      <div class="container">
        <div class="faq-group-header">
          <h2>{group.title}</h2>
        </div>
        <div class="faq-list">
          {group.faqs.map((faq, fi) => (
            <div class="faq-item">
              <button
                class="faq-q"
                aria-expanded="false"
                aria-controls={`faq-${group.id}-${fi}`}
                id={`faq-btn-${group.id}-${fi}`}
              >
                <span>{faq.q}</span>
                <span class="faq-toggle" aria-hidden="true">+</span>
              </button>
              <div
                class="faq-a"
                id={`faq-${group.id}-${fi}`}
                role="region"
                aria-labelledby={`faq-btn-${group.id}-${fi}`}
                hidden
              >
                <p set:html={faq.a} />
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- ─── Still Have Questions ─────────────────────────────────── -->
  <section class="section still-questions">
    <div class="container">
      <div class="still-inner">
        <div>
          <h2>Still Have Questions?</h2>
          <p>We're happy to help. Reach out directly or schedule a Meet &amp; Greet and ask in person — that's what it's for.</p>
        </div>
        <a href="/contact" class="btn btn-primary">Contact Us →</a>
      </div>
    </div>
  </section>

  <!-- ─── Bottom CTA ────────────────────────────────────────────── -->
  <section class="bottom-cta">
    <div class="container bottom-cta-inner">
      <div class="bottom-cta-text">
        <h2>Ready to Take the Next Step?</h2>
        <p>Start with a free, no-obligation meet and greet. No pressure. No commitment.</p>
      </div>
      <div class="bottom-cta-btns">
        <a href="/contact" class="btn btn-accent">Schedule a Free Meet &amp; Greet</a>
        <a href="/membership" class="btn btn-outline-white">Explore Membership Plans →</a>
      </div>
    </div>
  </section>

</MainLayout>

<style>
  /* ─── Hero ─────────────────────────────────── */
  .page-hero {
    background: var(--green-500);
    padding: clamp(48px, 8vw, 80px) 0;
  }
  .hero-eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--green-200);
    margin-bottom: 0.75rem;
  }
  .page-hero h1 { color: #ffffff; margin-bottom: 0.75rem; }
  .hero-desc {
    color: var(--green-100);
    font-size: clamp(1rem, 2vw, 1.15rem);
    max-width: 680px;
    line-height: 1.7;
    margin: 0;
  }
  .hero-link {
    color: #ffffff;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ─── Quick nav ─────────────────────────────── */
  .faq-nav {
    background: var(--cream-50);
    border-bottom: 1px solid var(--cream-300);
    padding: 0.75rem 0;
    position: sticky;
    top: 72px;
    z-index: 10;
  }
  .faq-nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.1rem;
    align-items: center;
  }
  .faq-nav-list li::after {
    content: '·';
    color: var(--ink-100);
    margin: 0 0.35rem;
    font-size: 0.8rem;
  }
  .faq-nav-list li:last-child::after { content: ''; }
  .faq-nav-list a {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--green-400);
    text-decoration: none;
    transition: color 0.15s;
    white-space: nowrap;
  }
  .faq-nav-list a:hover { color: var(--green-500); text-decoration: underline; }

  /* ─── FAQ groups ────────────────────────────── */
  .faq-group-section {
    background: var(--cream-100);
    padding: clamp(32px, 5vw, 56px) 0;
  }
  .faq-group-section.section-alt { background: var(--cream-200); }

  .faq-group-header {
    background: var(--green-500);
    border-radius: 12px;
    padding: 16px 24px;
    margin-bottom: 0.25rem;
  }
  .faq-group-header h2 {
    color: #ffffff;
    font-size: 1.1rem;
    margin: 0;
    font-family: var(--font-body);
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  /* ─── FAQ list ──────────────────────────────── */
  .faq-list {
    background: var(--cream-50);
    border-radius: 0 0 12px 12px;
    border: 1px solid var(--cream-300);
    border-top: none;
    overflow: hidden;
  }
  .faq-item { border-bottom: 1px solid var(--cream-300); }
  .faq-item:last-child { border-bottom: none; }
  .faq-q {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.1rem 1.5rem;
    background: none;
    border: none;
    font-family: var(--font-body);
    font-size: 0.97rem;
    font-weight: 500;
    color: var(--ink-900);
    cursor: pointer;
    text-align: left;
    transition: background 0.15s, color 0.15s;
  }
  .faq-q:hover {
    background: var(--green-50);
    color: var(--green-500);
  }
  .faq-toggle {
    font-size: 1.3rem;
    font-weight: 300;
    flex-shrink: 0;
    color: var(--green-400);
    transition: transform 0.2s;
    line-height: 1;
    min-width: 1.3rem;
    text-align: center;
  }
  .faq-q[aria-expanded="true"] {
    background: var(--green-50);
    color: var(--green-500);
  }
  .faq-q[aria-expanded="true"] .faq-toggle { transform: rotate(45deg); }
  .faq-a { padding: 0 1.5rem 1.25rem; }
  .faq-a p {
    color: var(--ink-500);
    font-weight: 300;
    line-height: 1.75;
    margin: 0;
    font-size: 0.95rem;
  }
  .faq-a :global(a) { color: var(--green-300); }

  /* ─── Still have questions ──────────────────── */
  .still-questions { background: var(--ink-50); }
  .still-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .still-inner h2 { color: var(--ink-900); margin-bottom: 0.5rem; }
  .still-inner p { color: var(--ink-700); font-size: 1rem; margin: 0; max-width: 480px; }

  /* ─── Bottom CTA ────────────────────────────── */
  .bottom-cta {
    background: var(--ink-900);
    padding: clamp(48px, 8vw, 80px) 0;
  }
  .bottom-cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .bottom-cta h2 { color: #ffffff; margin-bottom: 0.5rem; }
  .bottom-cta p { color: var(--ink-300); font-size: 1rem; max-width: 480px; margin: 0; }
  .bottom-cta-btns { display: flex; gap: 1rem; flex-wrap: wrap; flex-shrink: 0; }

  /* ─── Responsive ────────────────────────────── */
  @media (max-width: 860px) {
    .faq-nav { top: 60px; }
  }
  @media (max-width: 640px) {
    .faq-nav { display: none; }
    .still-inner { flex-direction: column; align-items: flex-start; }
    .bottom-cta-inner { flex-direction: column; align-items: flex-start; }
  }
</style>

<script>
  document.querySelectorAll('.faq-q').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const answerId = btn.getAttribute('aria-controls');
      const answer = answerId ? document.getElementById(answerId) : null;
      btn.setAttribute('aria-expanded', String(!expanded));
      if (answer) answer.hidden = expanded;
    });
  });
</script>
