---
export interface Props {
  title: string;
  description: string;
  author: string;
  date: string;
  slug: string;
  tags?: string[];
  featuredImage?: string;
}

const { title, description, author, date, slug, tags = [], featuredImage } = Astro.props;

const dateObj = new Date(date);
const dateFormatted = dateObj.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const dateISO = dateObj.toISOString();
---

<article class="blog-card card">
  {featuredImage && (
    <a href={`/blog/${slug}`} class="card-img-link" tabindex="-1" aria-hidden="true">
      <div class="card-img">
        <img
          src={featuredImage}
          alt=""
          loading="lazy"
          width="600"
          height="340"
        />
      </div>
    </a>
  )}
  <div class="card-body">
    {tags.length > 0 && (
      <div class="card-tags">
        {tags.slice(0, 2).map(t => <span class="badge">{t}</span>)}
      </div>
    )}
    <h3><a href={`/blog/${slug}`}>{title}</a></h3>
    <p class="card-desc">{description}</p>
    <footer class="card-footer">
      <span class="card-author">{author}</span>
      <time datetime={dateISO} class="card-date">{dateFormatted}</time>
    </footer>
  </div>
</article>

<style>
  .blog-card {
    padding: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .blog-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }
  .card-img {
    aspect-ratio: 16/9;
    overflow: hidden;
    background: var(--color-light);
  }
  .card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }
  .blog-card:hover .card-img img { transform: scale(1.04); }
  .card-body {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .card-tags {
    display: flex;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }
  .card-body h3 {
    font-size: 1.1rem;
    margin-bottom: 0.6rem;
    line-height: 1.3;
  }
  .card-body h3 a {
    color: var(--color-primary);
    text-decoration: none;
    transition: color 0.15s;
  }
  .card-body h3 a:hover { color: var(--color-secondary); }
  .card-desc {
    font-size: 0.9rem;
    color: #666;
    line-height: 1.65;
    flex: 1;
    margin-bottom: 1.25rem;
  }
  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.8rem;
    color: #999;
    border-top: 1px solid var(--color-light);
    padding-top: 0.75rem;
    margin-top: auto;
  }
  .card-author { font-weight: 600; color: #777; }
</style>
