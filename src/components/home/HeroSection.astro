---
import drLiebermanPhoto from '../../assets/staff/dr-philip-lieberman.jpg';
---

<section class="hero" aria-label="Hero">
  <div class="container hero-inner">
    <div class="hero-content">
      <span class="section-label">Wayne, PA · Main Line · Chester County</span>
      <h1>Primary Care That Treats You Like a Concierge Patient — At a Price That Makes Sense</h1>
      <p class="hero-sub">
        Wayne, PA's only Direct Primary Care practice with in-person,
        board-eligible Lifestyle Medicine. The attention and comprehensiveness
        of a concierge physician. The cost transparency and fiscal responsibility
        of Direct Primary Care. One flat monthly membership — no insurance,
        no rushed visits, no surprises.
      </p>
      <div class="hero-ctas">
        <a href="/contact" class="btn btn-accent hero-btn-primary">Schedule a Free Meet &amp; Greet</a>
        <a href="/membership" class="btn btn-outline hero-btn-secondary">See How Membership Works</a>
      </div>
      <div class="hero-trust">
        <span>✓ No insurance required</span>
        <span>✓ Free meet &amp; greet</span>
        <span>✓ Board-eligible Lifestyle Medicine</span>
      </div>
    </div>
    <div class="hero-visual" aria-hidden="true">
      <div class="hero-image-wrap">
        <img
          src={drLiebermanPhoto.src}
          alt="Dr. Philip Lieberman, MD — Forward Family Medicine"
          loading="eager"
          width="560"
          height="640"
          class="hero-img"
        />
        <div class="hero-badge">
          <span class="badge-icon">🏥</span>
          <div>
            <strong>Dual Board-Eligible</strong>
            <span>Family &amp; Lifestyle Medicine</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(160deg, var(--cream-100) 0%, var(--cream-300) 100%);
    padding: clamp(48px, 8vw, 96px) 0;
    overflow: hidden;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: clamp(2rem, 5vw, 5rem);
  }
  .hero-content .section-label {
    margin-bottom: 1rem;
  }
  .hero-content h1 {
    margin-bottom: 1.25rem;
    color: var(--ink-900);
  }
  .hero-sub {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: var(--ink-700);
    max-width: 540px;
    margin-bottom: 2rem;
    line-height: 1.7;
  }
  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.75rem;
  }
  .hero-btn-primary {
    font-size: 1.05rem;
    padding: 0.9rem 2rem;
  }
  .hero-btn-secondary {
    font-size: 1.05rem;
    padding: 0.9rem 2rem;
  }
  .hero-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
    font-size: 0.85rem;
    color: var(--ink-500);
    font-weight: 500;
  }
  .hero-trust span::before {
    color: var(--green-400);
  }

  /* Visual */
  .hero-visual {
    position: relative;
  }
  .hero-image-wrap {
    position: relative;
    border-radius: 20px;
    overflow: visible;
  }
  .hero-img {
    width: 100%;
    height: auto;
    border-radius: 20px;
    object-fit: cover;
    object-position: top center;
    box-shadow: var(--shadow-lg);
    max-height: 560px;
  }
  .hero-badge {
    position: absolute;
    bottom: -1rem;
    left: -1.5rem;
    background: var(--cream-50);
    border-radius: var(--radius);
    box-shadow: var(--shadow-md);
    padding: 0.9rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    max-width: 240px;
  }
  .badge-icon { font-size: 1.5rem; }
  .hero-badge strong {
    display: block;
    font-size: 0.85rem;
    color: var(--ink-900);
    line-height: 1.2;
  }
  .hero-badge span {
    font-size: 0.75rem;
    color: var(--ink-300);
  }

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }
    .hero-visual {
      order: -1;
    }
    .hero-img {
      max-height: 320px;
    }
    .hero-badge {
      bottom: -0.5rem;
      left: 0.5rem;
    }
  }
</style>
