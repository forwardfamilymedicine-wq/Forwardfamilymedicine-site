---
const credentials = [
  {
    title: 'Dual Board-Eligible',
    desc: 'Family Medicine + Lifestyle Medicine. Dr. Lieberman holds dual board eligibility — a combination virtually no other DPC practice on the Main Line can offer.',
  },
  {
    title: 'Culinary & Nutrition-Trained',
    desc: 'Real food knowledge, not generic advice. Dr. Lieberman earned degrees in culinary arts and nutrition science before medical school. When he talks about diet, he means it.',
  },
  {
    title: 'True DPC Model',
    desc: 'No insurance. Flat monthly membership. Direct access to your doctor — by phone, text, or email. Same-day appointments. This is what primary care should have always been.',
  },
];
---

<section class="credential-strip" aria-label="What makes us different">
  <div class="container">
    <div class="strip-grid">
      {credentials.map(c => (
        <div class="strip-item">
          <h3>{c.title}</h3>
          <p>{c.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .credential-strip {
    background: var(--green-500);
    padding: clamp(40px, 6vw, 72px) 0;
  }
  .strip-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
  }
  .strip-item {
    color: rgba(255,255,255,0.9);
  }
.strip-item h3 {
    color: white;
    font-size: 1.1rem;
    margin-bottom: 0.6rem;
  }
  .strip-item p {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.75);
    line-height: 1.7;
    margin: 0;
  }

  @media (max-width: 700px) {
    .strip-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
