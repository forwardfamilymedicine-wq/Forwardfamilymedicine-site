      <circle cx="240" cy="34" r="4" fill="rgba(62,99,68,0.18)" transform="rotate(180 240 240)"/>
      <circle cx="240" cy="34" r="4" fill="rgba(62,99,68,0.18)" transform="rotate(210 240 240)"/>
