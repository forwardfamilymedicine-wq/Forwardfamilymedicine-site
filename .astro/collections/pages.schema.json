{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "canonical": {
      "type": "string"
    },
    "date": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "noindex": {
      "default": false,
      "type": "boolean"
    },
    "schemaType": {
      "type": "string"
    },
    "image": {
      "type": "string"
    },
    "imageAlt": {
      "type": "string"
    },
    "imageWidth": {
      "type": "number"
    },
    "imageHeight": {
      "type": "number"
    },
    "linksTo": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description"
  ]
}